{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "PHDL",
    "scopeName": "source.phdl",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#storage-modifiers"
        },
        {
            "include": "#types"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#system-functions"
        },
        {
            "include": "#events"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.documentation.phdl",
                    "match": "///.*$"
                },
                {
                    "name": "comment.line.double-slash.phdl",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.phdl",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.phdl",
                    "match": "\\b(if|else|for|in|match|return|when|as|select)\\b"
                },
                {
                    "name": "keyword.other.phdl",
                    "match": "\\b(use|pub)\\b"
                }
            ]
        },
        "storage-modifiers": {
            "patterns": [
                {
                    "name": "storage.type.phdl",
                    "match": "\\b(mod|discipline|bundle|enum|capability|impl|fn|analog|digital|bench)\\b"
                },
                {
                    "name": "storage.modifier.phdl",
                    "match": "\\b(param|wire|var|input|output|inout|const)\\b"
                },
                {
                    "name": "entity.name.type.phdl",
                    "match": "\\b(potential|flow|storage|resolve|tri|and|or|nature)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.phdl",
                    "match": "\\b(Real|Natural|Integer|Complex|Boolean|Quad|String|Electrical|Thermal|Ground|Void|Bit|Logic|Vec|Option|Map|Waveform|OpConfig|TranConfig|AcConfig|NoiseConfig|Solver|Scale|CrossDir)\\b"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.phdl",
            "begin": "\"",
            "end": "\""
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.phdl",
                    "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
                },
                {
                    "name": "constant.numeric.si.phdl",
                    "match": "\\b[0-9.]+(T|G|meg|k|m|u|n|p|f|a)\\b"
                },
                {
                    "name": "constant.numeric.integer.phdl",
                    "match": "\\b(0[xX][0-9a-fA-F]+|0[bB][01]+|0[oO][0-7]+|0[qQ][01xXzZ]+|[0-9]+)\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.phdl",
                    "match": "<\\+|<-|=|=>"
                },
                {
                    "name": "keyword.operator.comparison.phdl",
                    "match": "==|!=|<=|>=|<|>"
                },
                {
                    "name": "keyword.operator.arithmetic.phdl",
                    "match": "\\+|\\-|\\*\\*|\\*|/|%|\\^"
                },
                {
                    "name": "keyword.operator.range.phdl",
                    "match": "\\.\\.=|\\.\\."
                },
                {
                    "name": "keyword.operator.bitwise.phdl",
                    "match": "&|\\||!"
                },
                {
                    "name": "keyword.operator.path.phdl",
                    "match": "::"
                },
                {
                    "name": "keyword.operator.event.phdl",
                    "match": "@"
                }
            ]
        },
        "system-functions": {
            "patterns": [
                {
                    "name": "support.function.phdl",
                    "match": "\\$(temperature|vt|abstime|mfactor|bound_step|discontinuity|finish|display|strobe|monitor|write|error|warn|warning|fatal|info|limit|random|simparam|param_given|port_connected|xposition|yposition|angle|analysis|dist_\\w+|op|tran|ac|noise|assert|plot)"
                },
                {
                    "name": "support.function.phdl",
                    "match": "\\b(V|I|ddt|idt|idtmod|ddx|delay|absdelay|transition|slew|laplace_np|laplace_zp|laplace_pm|laplace_nm|laplace_npm|zi_zd|zi_zp|zi_nd|zi_np|white_noise|flicker_noise|ac_stim|analysis|abs|exp|ln|log|sqrt|sin|cos|tan|floor|ceil|pow|min|max)\\s*(?=\\()"
                }
            ]
        },
        "events": {
            "patterns": [
                {
                    "name": "constant.language.phdl",
                    "match": "\\b(posedge|negedge|change|cross|above|initial|final|timer)\\b"
                }
            ]
        }
    }
}
