// NMOS level 3 fixed gate bias, Rd load — same circuit as nmos3_fixed.cir.
use piperine::disciplines;
use spice::sources;
use spice::passives;
use spice::mos;
mod Top() {
    wire gnd: Electrical; wire vdd: Electrical; wire g: Electrical; wire d: Electrical;
    vd: vsrc (.p=vdd,.n=gnd) { .dc = 10.0 };
    vg: vsrc (.p=g,.n=gnd) { .dc = 2.0 };
    r1: res  (.p=vdd,.n=d) { .r = 100.0e3 };
    m1: mos3 (.d=d,.g=g,.s=gnd,.b=gnd)
        { .l = 2.0e-6, .w = 10.0e-6, .model = Mos3Model { .vto = 1.0, .kp = 2.0e-5 } };
}
