// NMOS level 2 Id-Vgs sweep — same circuit as nmos2_id_vgs.cir; the
// harness stages vg.dc per sweep point and reads vd's branch current.
use piperine::disciplines;
use spice::sources;
use spice::mos;
mod Top() {
    wire gnd: Electrical; wire d: Electrical; wire g: Electrical;
    vd: vsrc (.p=d,.n=gnd) { .dc = 3.0 };
    vg: vsrc (.p=g,.n=gnd) { .dc = 0.0 };
    m1: mos2 (.d=d,.g=g,.s=gnd,.b=gnd)
        { .l = 2.0e-6, .w = 10.0e-6,
          .model = Mos2Model { .vto = 1.0, .kp = 2.0e-5, .nsub = 1.0e15, .nfs = 1.0e11,
                               .lambda = 0.02, .rd = 100.0, .rs = 100.0 } };
}
