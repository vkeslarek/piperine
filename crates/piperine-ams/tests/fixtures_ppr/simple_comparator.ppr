// `include "disciplines.vams"

// `ifdef insideADMS
//     `define INITIAL_MODEL @(initial_model)
// `else
//     `define INITIAL_MODEL
// `endif

mod comparator ( inout sigin : Electrical, inout sigref : Electrical, inout sigout : Electrical ) {

    param sigout_high : Real = 10.0;
    param sigout_low : Real = -10.0;
    param sigin_offset : Real = 0.0;
    param comp_slope : Real = 1000.0;

    analog comparator {

        // `INITIAL_MODEL
        begin
            if (sigout_high <= sigout_low) begin
                $display("Range specification error. sigout_high = (%E) less than sigout_low = (%E).\n", sigout_high, sigout_low);
            end
        end

        V(sigout) <+ 0.5 * (sigout_high - sigout_low) * tanh(comp_slope * (V(sigin, sigref) - sigin_offset)) + (sigout_high + sigout_low) / 2.0;
    }
}

endmodule