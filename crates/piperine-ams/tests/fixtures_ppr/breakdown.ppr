// Warn on Breakdown
//
// Version 1a, 1 June 04
//
// Ken Kundert
//
// Downloaded from The Designer's Guide Community (www.designers-guide.org).
// Post any questions on www.designers-guide.org/Forum.
// Taken from "The Designer's Guide to Verilog-AMS" by Kundert & Zinke.
// Chapter 5, Listing 4.
//
// This is the version given in the book, but it does not
// run in the existing version of Spectre (5.0 May 03). See breakdown2.vams
// for an alternate version that does run in Spectre.

mod breakdown(n);
    // message emitted when this level is exceeded (V)
    param threshold : Real = 1000.0;
    // the message to print
    param message : String = "Warning: breakdown voltage exceeded.";

    wire n : Voltage;

    var given : Integer;

    analog breakdown {
        // above(expr) -> cross(expr)
        @ cross(V(n) - threshold) begin
            if (!given) $strobe(message);
            given = 1;
        end
    }
endmod