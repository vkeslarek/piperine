// Enhanced Bidirectional Connect Module
//
// Version 1a, 1 June 04
//
// Olaf Zinke
//
// Downloaded from The Designer's Guide Community (www.designers-guide.org).
// Post any questions on www.designers-guide.org/Forum.
// Taken from "The Designer's Guide to Verilog-AMS" by Kundert & Zinke.
// Chapter 4, Listing 20.

// connectmodule -> mod with note

mod bidir(a, d);
    // output voltage for a logic 0 (V)
    param v0 : Real = 0.0;
    // output voltage for a logic 1 (V)
    param v1 : Real = 5.0;
    // pull-up resistance when 1 or x (W)
    param ruon : Real = 1k from(0 : inf);
    // pull-up resistance when 0 or z (W)
    param ruoff : Real = 1M from(0 : inf);
    // pull-down resistance when 1 or x (W)
    param rdon : Real = 1k from(0 : inf);
    // pull-down resistance when 0 or z (W)
    param rdoff : Real = 1M from(0 : inf);
    // rise time (s)
    param tr : Real = 1n from [ 0 : inf);
    // fall time (s)
    param tf : Real = 1n from [ 0 : inf);
    // maximum voltage of a logic 0 (V)
    param vl : Real = 0.5;
    // minimum voltage of a logic 1 (V)
    param vh : Real = 2.7;
    // absolute max current allowed in HiZ state
    param maxzi : Real = 0.1u;
    // time in the Xrange before dout gets x
    param xdelay : Real = 1;
    // max time of current > maxzi before going out of z state
    param zdelay : Real = 0.5 * xdelay;

    wire a : Electrical;
    var d : Logic;

    param guon : Real = 1.0 / ruon;
    param guoff : Real = 1.0 / ruoff;
    param gdon : Real = 1.0 / rdon;
    param gdoff : Real = 1.0 / rdoff;

    var v : Real;
    var r : Real;
    var gu : Real;
    var gd : Real;
    var vstate : Integer;
    var istate : Logic;
    var inXrange : Logic;
    var outOfZcurrent : Logic;
    var DrCount : Integer;
    var i : Integer;
    var XCount : Integer;
    var ZCount : Integer;
    var LCount : Integer;
    var HCount : Integer;
    var dout : Logic;

    @ initial {
        dout = 1'bz;
        vstate = 2;
        istate = 0;
        inXrange = 0;
        outOfZcurrent = 0;
        DrCount = $driver_count(d);
        XCount = 0;
        ZCount = 0;
        LCount = 0;
        HCount = 0;
    }

    @ driver_update(d) {
        XCount = 0;
        ZCount = 0;
        LCount = 0;
        HCount = 0;
    }

    // above(expr) -> cross(expr)
    @ cross(V(a) - vh) {
        vstate = 1;
        inXrange = 0;
    }
    @ cross(vh - V(a)) inXrange = 1;
    @ cross(V(a) - vl) inXrange = 1;
    @ cross(vl - V(a)) {
        vstate = 3;
        inXrange = 0;
    }

    @ posedge(inXrange) {
        // XRangeDelay # xdelay
        vstate = 2;
        inXrange = 0;
    }
    @ negedge(inXregion) disable XRangeDelay;

    @ posedge(outOfZcurrent) {
        // outOfZCurrentDelay # zdelay
        istate = 1;
        outOfZcurrent = 0;
    }
    @ negedge(outOfZcurrent) disable outOfZCurrentDelay;

    @ cross(abs(I(a)) - maxzi) outOfZcurrent = 1;
    @ cross(maxzi - abs(I(a))) {
        istate = 0;
        outOfZcurrent = 0;
    }

    analog bidir {
        // transition() limitation - ddt approximation or comment needed
        V(a) <+ v;
    }
endmod