mod hicumL0_v2p0p0(inout c : Electrical, inout b : Electrical, inout e : Electrical, inout s : Electrical, inout tnode : Electrical) {
    wire c : Electrical, b : Electrical, e : Electrical, s : Electrical, tnode : Electrical;
    // Many internal nodes and branches
    wire ci : Electrical, bi : Electrical, ei : Electrical;

    // Collector current parameters
    param is : Real = 1.0e-16; // constraint: is >= 0
    param mcf : Real = 1.00; // constraint: 0 < mcf <= 10
    param mcr : Real = 1.00; // constraint: 0 < mcr <= 10
    param vef : Real = 1.0e6; // constraint: vef >= 0
    param ver : Real = 1.0e6; // constraint: ver >= 0
    param iqf : Real = 1.0e6; // constraint: iqf >= 0
    param iqr : Real = 1.0e6; // constraint: iqr >= 0

    // Base current parameters
    param ibes : Real = 1e-18; // constraint: 0 <= ibes <= 1
    param mbe : Real = 1.0; // constraint: 0 < mbe <= 10
    param ires : Real = 0.0; // constraint: 0 <= ires <= 1
    param mre : Real = 2.0; // constraint: 0 < mre <= 10
    param ibcs : Real = 0.0; // constraint: 0 <= ibcs <= 1
    param mbc : Real = 1.0; // constraint: 0 < mbc <= 10

    // Capacitance parameters
    param cje0 : Real = 1.0e-20; // constraint: cje0 >= 0
    param vde : Real = 0.9; // constraint: 0 < vde <= 10
    param ze : Real = 0.5; // constraint: 0 < ze <= 1
    param aje : Real = 2.5; // constraint: aje >= 1

    // Transit time parameters
    param t0 : Real = 0.0; // constraint: t0 >= 0
    param tef0 : Real = 0.0; // constraint: tef0 >= 0
    param tr : Real = 0.0; // constraint: tr >= 0

    // Critical current parameters
    param rci0 : Real = 150; // constraint: rci0 >= 0
    param vpt : Real = 100; // constraint: 0 < vpt <= 100

    // Base resistance parameters
    param rbi0 : Real = 0.0; // constraint: rbi0 >= 0
    param rbx : Real = 0.0; // constraint: rbx >= 0
    param rcx : Real = 0.0; // constraint: rcx >= 0
    param re : Real = 0.0; // constraint: re >= 0

    // Temperature parameters
    param tnom : Real = 27.0; // constraint: tnom >= 0
    param dtemp : Real = 0.0;

    // Self-heating
    param flsh : Natural = 0; // constraint: 0 <= flsh <= 2
    param rth : Real = 0.0; // constraint: rth >= 0
    param cth : Real = 0.0; // constraint: cth >= 0

    // Note: Complex analog behavioral code with macros QJMODF, QJMOD, HICJQ
    // not directly translatable - requires manual translation

    analog hicumL0_v2p0p0 {
        // Behavioral code not directly translatable
    }
}