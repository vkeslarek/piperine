//Compact Model Coalition.
//
//Version number: 3.2.0officialrelease
//
// Updates from v3.1.0 official release:
// 1. External thermal node added
// 2. p-GaN Implementation
//    a. parameters related to p-GaN junction diode and junction capacitor
//    b. added new node gi2p: from top to bottom we have g, gi1, gi2, gi2p
//    c. any connection to gi2 in v3.1.0 is now connected to gi2p except field plate gate connections
//    d. all field plate connections remain to gi2 so they connect to outside of the pGan layer
//    e. connected end of rg2 to gi2
//    f. added local variables related to floating p-gan behavior
//    g. added idsh calculation, csh calculation and contribution
//    h. added collapse of gi2 and gi2p if p-GaN calculations are off (flagpgan=0)

mod mvsg_cmc(d, g, s, b, dt);
    inout d, g, s, b, dt;
    wire d, g, s, b : Electrical;
    wire dt : Thermal;
    wire di, gi1, gi2, gi2p, si, fps1, fps2, fps3, fps4, fp1, fp2, fp3, fp4, drc, src : Electrical;
    wire tr, tr1, dtrapin, dtrapin2, dtrapin3, gtrapin, gtrapin2, gtrapin3 : Electrical;
    wire xt1, xt2 : Electrical;

    // Instance parameters
    param w : Real = 180.0e-6;
    param l : Real = 250.0e-9;
    param ngf : Integer = 1;
    param dtemp : Real = 0.0;

    // Model parameters - Transport
    param version : Real = 3.20;
    param tnom : Real = 27.0;
    param type : Integer = 1;
    param cg : Real = 4.00e-03;
    param tcg : Real = 0.0;
    param cofsm : Real = 0.0;
    param cofdm : Real = 0.0;
    param cofdsm : Real = 0.0;
    param cofdsubm : Real = 0.0;
    param cofssubm : Real = 0.0;
    param cofgsubm : Real = 0.0;
    param cofsm0 : Real = 0.0;
    param cofdm0 : Real = 0.0;
    param cofdsm0 : Real = 0.0;
    param cofdsubm0 : Real = 0.0;
    param cofssubm0 : Real = 0.0;
    param cofgsubm0 : Real = 0.0;
    param tcofs : Real = 0.0;
    param tcofd : Real = 0.0;
    param tcofds : Real = 0.0;
    param tcofssub : Real = 0.0;
    param tcofdsub : Real = 0.0;
    param tcofgsub : Real = 0.0;
    param vtfrin : Real = -50;
    param nfrin : Real = 1e2;
    param rsh : Real = 150.0;
    param rcs : Real = 800e-6;
    param rcd : Real = 800e-6;
    param vx0 : Real = 3.0e5;
    param mu0 : Real = 0.135;
    param beta : Real = 1.50;
    param vto : Real = -2.72;
    param ss : Real = 0.120;
    param delta1 : Real = 16e-3;
    param delta2 : Real = 0.0;
    param dibsat : Real = 10.0;
    param nd : Real = 0.0;
    param alpha : Real = 3.5;
    param lambda : Real = 0.0;
    param vtheta : Real = 0.0;
    param mtheta : Real = 0.0;
    param vzeta : Real = 150e3;
    param vtzeta : Real = -0.4e-3;
    param epsilon : Real = 2.3;
    param rct1 : Real = 0.0;
    param rct2 : Real = 0.0;
    param flagres : Integer = 0;
    param flagsp : Integer = 0;

    // Source access region parameters
    param lgs : Real = 3.0e-6;
    param vtors : Real = -650;
    param cgrs : Real = 5.0e-3;
    param vx0rs : Real = 100e3;
    param mu0rs : Real = 100e-3;
    param betars : Real = 1.00;
    param delta1rs : Real = 100e-3;
    param srs : Real = 0.100;
    param ndrs : Real = 0.0;
    param vthetars : Real = 0.0;
    param mthetars : Real = 0.0;
    param alphars : Real = 3.5;

    // Drain access region parameters
    param lgd : Real = 4.85e-6;
    param vtord : Real = -650;
    param cgrd : Real = 4.3e-3;
    param vx0rd : Real = 100e3;
    param mu0rd : Real = 100e-3;
    param betard : Real = 1.00;
    param delta1rd : Real = 0.35;
    param srd : Real = 0.3;
    param ndrd : Real = 3.8;
    param vthetard : Real = 0.0;
    param mthetard : Real = 0.0;
    param alphard : Real = 3.5;

    // Field-Plate parameters (4 source-side + 4 drain-side)
    // (similar structure with temperature coefficients)

    // Gate leakage parameters
    param igmod : Integer = 0;
    param fracig : Real = 0;
    param vjg : Real = 1.1;
    param pg_param1 : Real = 820e-3;
    // ... additional gate leakage params

    // p-GaN junction parameters
    param flagpgan : Integer = 0;
    param pg_param_pgan : Real = 0.05;
    param ij_pgan : Real = 9.0e-10;
    param pgsrec_pgan : Real = 0.013;
    param irec_pgan : Real = 4.5e-9;
    param vcsh0 : Real = 2.0;
    param csh0 : Real = 6e-8;

    // Channel breakdown with debiasing
    param icbdmod : Integer = 0;
    param cbddbmod : Integer = 1;

    // Thermal sub-circuit parameters
    param rth : Real = 25;
    param cth : Real = 1e-4;

    // RF gm-dispersion parameters
    param gmdisp : Integer = 0;
    param taugmrf : Real = 1e-3;

    // Layout and DC-to-RF gate-resistance parameters
    param rgsp : Real = 0.0;
    param ngcon : Real = 1;
    param lovg : Real = 0;
    param agate : Real = 1;

    // Trapping model parameters
    param trapselect : Integer = 0;
    param rintrap1 : Real = 1e9;
    param ctrap : Real = 1e-3;
    param vttrap : Real = 100;
    param taut : Real = 3e-5;
    param alphat1 : Real = 1e-3;
    param alphat2 : Real = 0.05;
    param alphat3 : Real = 1e-3;
    param tempt : Real = 1e-4;
    // ... additional trapping params

    // Noise model parameters
    param noisemod : Integer = 0;
    param shs : Real = 3.0;
    param shd : Real = 3.0;
    param kf : Real = 1.0e-4;
    param af : Real = 2.0;
    param ffe : Real = 1.2;

    // Minimum element parameters
    param minr : Real = $simparam("minr", 1m);
    param minl : Real = 1.0e-9;
    param minc : Real = 0.0;

    // Internal functions: absfunc, mmax, explim, calc_iq, calc_ig, calc_capt

    fn real absfunc(x : Real) -> Real;
    begin
        absfunc = sqrt(x * x + 4.0 * 1e-5);
    endfn

    fn real mmax(x : Real, y : Real) -> Real;
    begin
        mmax = 0.5 * (x + y + sqrt((x - y) * (x - y) + 4.0 * 1e-5));
    endfn

    fn real explim(x : Real) -> Real;
    begin
        if (x > `M_MAXEXP) begin
            explim = exp(`M_MAXEXP) * (1.0 + (x - `M_MAXEXP));
        end
        else begin
            if (x < -`M_MAXEXP) begin
                explim = exp(-`M_MAXEXP);
            end
            else begin
                explim = exp(x);
            end
        end
    endfn

    analog begin
        gmin = $simparam("gmin", 0);
        tnomk = tnom + `P_CELSIUS0;
        tambk = $temperature;

        if ($port_connected(dt) == 0);
        tsh = Temp(dt);
        tdut = tambk + dtemp + tsh;

        // p-GaN behavior when flagpgan = 1
        // Trap model behavior when trapselect > 0
        // Temperature-dependent parameter calculations
        // Internal circuit behavior
    end
endmod