// Lossy Inductor
//
// Version 1a, 1 June 04
//
// Ken Kundert
//
// Downloaded from The Designer's Guide Community (www.designers-guide.org).
// Post any questions on www.designers-guide.org/Forum.
// Taken from "The Designer's Guide to Verilog-AMS" by Kundert & Zinke.
// Chapter 3, Listing 28.

// Note: This file uses a `skin_effect` module which is defined separately in lossy-inductor.va
// In Piperine HDL, this module uses a Laplace transfer function (laplace_zp) which has
// no direct equivalent. The behavioral description would need to be approximated.

mod lossy_ind(inout t1 : Electrical, inout t2 : Electrical) {
    param esr : Real = 0.01; // constraint: esr >= 0 (equivalent series resistance (Ohms))
    param rcp : Real = 1.0; // constraint: rcp >= 0 (series resistance of shunt C (Ohms))
    param cp : Real = 10e-15; // constraint: cp >= 0 (shunt capacitance (F))
    param l : Real = 1e-9; // constraint: l >= 0 (inductance (H))
    param h : Real = 70000; // constraint: h >= 1 (magnitude of skin effect at 1Hz (Ohms))
    wire t1 : Electrical, t2 : Electrical;
    wire n1 : Electrical, n2 : Electrical;
    // Instance connections would be:
    // resistor # (.r(rcp)) Rp(n2, t2);
    // skin_effect # (.r0(esr),.f0(2 * esr * esr * h * h),.f1(1 / (2 * M_PI * sqrt(l * cp)))) Hr(t1, n1);
    // capacitor # (.c(cp)) Cp(t1, n2);
    // inductor # (.l(l)) L(n1, t2);
    // Note: Full structural translation requires the skin_effect module which uses
    // laplace_zp function - not directly representable in PHDL analog blocks
}