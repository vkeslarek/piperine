// Convert Cartesian coordinates to polar coordinates

mod CartToPol(cart, pol) {
    input cart[0:1] : Optical; // cart[0] is real part, and cart[1] is imaginary part
    output pol[0:1] : Optical; // pol[0] is amplitude, and pol[1] is phase

    analog CartToPol {
        OptE(pol[0]) <+ sqrt(pow(OptE(cart[0]), 2) + pow(OptE(cart[1]), 2)); // Amplitude
        OptE(pol[1]) <+ atan2(OptE(cart[1]), OptE(cart[0])); // Phase
    }
}