// Voltage Controlled Oscillator
//
// Version 1a, 1 June 04
//
// Olaf Zinke
//
// Downloaded from The Designer's Guide Community (www.designers-guide.org).
// Post any questions on www.designers-guide.org/Forum.
// Taken from "The Designer's Guide to Verilog-AMS" by Kundert & Zinke.
// Appendix A, Listing 8.

// `include "disciplines.vams"
// `timescale 1ns / 1ps

mod vco ( output out : Logic, inout ps : Electrical, inout ns : Electrical ) {
    param f0 : Real = 100e3; // center frequency (Hz)
    param kvco : Real = 10e3; // gain (Hz/V)
    param rin : Real = 100e3; // from(0:inf) // input resistance (Ohms)

    var vin : Real;

    digital vco {
        var out_val : Bit = 0;

        initial out_val = 0;

        // NOTE: # delay not directly supported in PHDL digital blocks
        // This would require a different approach
        always begin
            vin = V(ps, ns);
            // Timing would need to be handled differently
            out_val = !out_val;
        end

        out <- out_val;
    }

    analog vco {
        I(ps, ns) <+ V(ps, ns) / rin;
    }
}

endmodule