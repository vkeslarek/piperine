endmod

//
// 3-input Nand gate
//

mod anand3(out, in1, in2, in3, dd);

    output out;
    voltage out;
    input in1, in2, in3;
    voltage in1, in2, in3;
    input dd;
    voltage dd;
    param td : Real = 0 from [ 0 : inf);
    // delay to start of output transition
    param tt : Real = 0 from [ 0 : inf);
    // transition time of output signals

    var lout : Integer;

    analog begin
        // make sure simulator sees the threshold crossings
        @(cross(V(in1) - V(dd) / 2) or cross(V(in2) - V(dd) / 2) or cross(V(in3) - V(dd) / 2));

        // compute the logical value of the output
        if ((V(in1) > V(dd) / 2) && (V(in2) > V(dd) / 2) && (V(in3) > V(dd) / 2)) lout = 0;
        else lout = 1;

        // create an analog version of logical output
        V(out) <+ V(dd) * transition(lout, td, tt);
    end
endmod