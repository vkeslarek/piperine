    // transition time of output signals

    var lout : Integer;

    analog begin
        // make sure simulator sees the threshold crossings
        @(cross(V(in1) - V(dd) / 2) or cross(V(in2) - V(dd) / 2));

        // compute the logical value of the output
        if ((V(in1) > V(dd) / 2) || (V(in2) > V(dd) / 2)) lout = 0;
        else lout = 1;

        // create an analog version of logical output
        V(out) <+ V(dd) * transition(lout, td, tt);
    end
endmod

