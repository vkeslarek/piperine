// Frequency dividers
//
// divider1: a simple frequency divider
// divider2: a frequency divider that exhibits gaussian synchronous jitter
//
// Version 1d, 16 June 2024
//
// Ken Kundert, Hua Li
//
// Downloaded from The Designer's Guide (www.designers-guide.org).
// Post any questions to www.designers-guide.org/Forum

//
// This model exhibits no jitter
//

mod divider1(out, in);

    output out;
    voltage out;
    // output
    input in;
    voltage in;
    // input (edge triggered)
    param vh : Real = +1;
    // output voltage in high state
    param vl : Real = -1;
    // output voltage in low state
    param vth : Real = (vh + vl) / 2;
    // threshold voltage at input
    param ratio : Integer = 2 from [ 2 : inf);
    // divide ratio
    param dir : Integer = 1 from [ -1 : 1 ] exclude 0;
    // dir=1 for positive edge trigger
    // dir=-1 for negative edge trigger
    param tt : Real = 1n from (0 : inf);
    // transition time of output signal
    param td : Real = 0 from [ 0 : inf);
    // average delay from input to output
    var count : Integer;
    var n : Integer;

    analog begin
        @(cross(V(in) - vth, dir)) begin
            count = count + 1;
            if (count >= ratio) count = 0;
            n = (2 * count >= ratio);
        end
        V(out) <+ transition(n ? vh : vl, td, tt);
    end
endmod

//
// This model exhibits white synchronous jitter
//

mod divider2(out, in);

    output out;
    voltage out;
    // output
    input in;
    voltage in;
    // input (edge triggered)
    param vh : Real = +1;
    // output voltage in high state
    param vl : Real = -1;
    // output voltage in low state
    param vth : Real = (vh + vl) / 2;
    // threshold voltage at input
    param ratio : Integer = 2 from [ 2 : inf);
    // divide ratio
    param dir : Integer = 1 from [ -1 : 1 ] exclude 0;
    // dir=1 for positive edge trigger
    // dir=-1 for negative edge trigger
    param tt : Real = 1n from (0 : inf);
    // transition time of output signal
    param td : Real = 0 from [ 0 : inf);
    // average delay from input to output
    param jitter : Real = 0 from [ 0 : td / 5 ];
    // edge-to-edge jitter
    param ttol : Real = 1p from [ 0 : td / 5 ];
    // time tolerance, recommend ttol << jitter
    var count : Integer;
    var n : Integer;
    var seed : Integer;
    var dt : Real;

    analog
    initial seed = -311;

    analog begin
        @(cross(V(in) - vth, dir, ttol)) begin
            count = count + 1;
            // count input transitions
            if (count >= ratio) count = 0;
            n = (2 * count >= ratio);
            dt = jitter * $rdist_normal(seed, 0, 1);
        end
        V(out) <+ transition(n ? vh : vl, td + dt, tt);
    end
endmod