/*
 * N-bit Analog / Digital Converters
 *
 * Input range is from vmin to vmax.
 *
 * Version 1c, 10 February 2008
 * Ken Kundert
 *
 * Downloaded from The Designer's Guide Community (www.designers-guide.org).
 * Post any questions on www.designers-guide.org/Forum.
 *
 * This ADC is preferred over the version given in Listing 26 of Chapter 3
 * of "The Designer's Guide to Verilog-AMS" by Kundert & Zinke.
 *
 * These versions comply with the Verilog-AMS LRM (vers. 2.1) but do not
 * run in the existing version of Spectre (6.1.1 May 2007).
 * See converter-spectre.vams for alternate versions that run in Spectre.
 */

// N-bit Analog to Digital Converter

mod adc(out, in, clk) {
    param bits : Natural = 8 from [1:24]; // resolution (bits)
    param vmin : Real = 0.0; // minimum input voltage (V)
    param vmax : Real = 1.0 from(vmin:inf); // maximum input voltage (V)
    param td : Real = 0 from [0:inf]; // delay from clock edge to output (s)
    param tt : Real = 0 from [0:inf]; // transition time of output (s)
    param vdd : Real = 5; // voltage level of logic 1 (V)
    param vss : Real = 0; // voltage level of logic 0 (V)
    param thresh : Real = (vdd + vss) / 2; // logic threshold level (V)
    param dir : Integer = +1 from [-1:1] exclude 0; // 1 for trigger on rising edge, -1 for falling
    localparam levels : Natural = 1 << bits;
    input in : Voltage, clk : Voltage;
    output out[bits-1:0] : Voltage;
    var result : Integer;
    // genvar i;

    analog adc {
        @(cross(V(clk) - thresh, dir) or initial_step) begin
            result = levels * ((V(in) - vmin)) / (vmax - vmin);
            if (result > levels - 1) result = levels - 1;
            else if (result < 0) result = 0;
            else end

            // transition not fully supported - simplified
            for (i = 0; i < bits; i = i + 1) begin
                V(out[i]) <+ (result & (1 << i)) ? vdd : vss;
            end
        end
    }
}

// N-bit Digital to Analog Converter

mod dac(out, in, clk) {
    param bits : Natural = 8 from [1:24]; // resolution (bits)
    param vmin : Real = 0.0; // minimum input voltage (V)
    param vmax : Real = 1.0 from(vmin:inf); // maximum input voltage (V)
    param td : Real = 0; // delay from clock edge to output (s)
    param tt : Real = 0; // transition time of output (s)
    param vdd : Real = 5.0; // voltage level of logic 1 (V)
    param vss : Real = 0; // voltage level of logic 0 (V)
    param thresh : Real = (vdd + vss) / 2; // logic threshold level (V)
    param dir : Integer = +1 from [-1:1] exclude 0; // 1 for trigger on rising edge, -1 for falling
    localparam fullscale : Real = vmax - vmin;

    output out : Voltage;
    input in[bits-1:0] : Voltage;
    input clk : Voltage;
    var aout : Real;
    var weight : Integer;
    // genvar i;

    analog dac {
        @(cross(V(clk) - thresh, dir) or initial_step) begin
            aout = 0;
            weight = 2;
            for (i = bits - 1; i >= 0; i = i - 1) begin
                if (V(in[i]) > thresh) begin
                    aout = aout + fullscale / weight;
                end
                weight = weight * 2;
            end
        end
        V(out) <+ aout + vmin; // Simplified transition
    }
}