// Note: This is a complex compact model file with ~700+ lines of code
// Simplified translation for structure - many parameters and equations

mod angelov_gan(d, g, s, t, rf);
    // Instance parameters - see original file for full parameter list
    param Noise : Integer = 1 from [ 0 : 2 ];
    param Selft : Integer = 0 from [ 0 : 1 ];
    param Trise : Real = 0.0 from(-inf : inf);
    param Temp : Real = 25.0 from(-273.15 : inf);
    param Idsmod : Integer = 0 from [ 0 : 4 ];
    param Igmod : Integer = 0 from [ 0 : 1 ];
    param Capmod : Integer = 2 from [ 0 : 4 ];
    param Noimod : Integer = 0 from [ 0 : 2 ];
    param Ipk0 : Real = 0.05;
    param Vpks : Real = -0.2;
    param Dvpks : Real = 0.2;
    param P1 : Real = 0.8;
    param P2 : Real = 0.0;
    param P3 : Real = 0.0;
    param Alphar : Real = 0.1;
    param Alphas : Real = 1.0;
    param Lambda : Real = 0.001;
    param Lvg : Real = 0.0;
    param B1 : Real = 0.1;
    param B2 : Real = 4.0;
    param Lsb0 : Real = 0.0;
    param Vtr : Real = 50.0;
    param Vsb2 : Real = 0.0;
    param Ebd : Real = 0.2;
    param Cds : Real = 0.0 from [ 0 : inf);
    param Cgspi : Real = 0.0;
    param Cgs0 : Real = 0.0;
    param Cgdpi : Real = 0.0;
    param Cgdpe : Real = 0.0 from [ 0 : inf);
    param Cgd0 : Real = 0.0;
    param P10 : Real = 0.0 from [ - 100 : 1000 ];
    param P11 : Real = 1.0 from(0 : 10 ];
    param P20 : Real = 0.0 from [ - 2 : 5 ];
    param P21 : Real = 0.2 from [ 0.01 : 5 ];
    param P30 : Real = 0.0 from [ - 2 : 5 ];
    param P31 : Real = 0.2 from [ 0.01 : 5 ];
    param P40 : Real = 0.0 from [ - 100 : 1000 ];
    param P41 : Real = 1.0 from [ 0.1 : 10 ];
    param P111 : Real = 0.0 from [ 0 : 1 ];
    param P222 : Real = 0.0 from [ 0 : 5 ];
    param P10pk : Real = 1.0 from [ - 100 : 100 ] exclude 0.0;
    param m : Real = 0.5;
    param Ij : Real = 0.00005 from [ 0 : inf);
    param Pg : Real = 15.0 from [ 0 : inf);
    param Ne : Real = 1.0 from [ 1 : 3 ];
    param Vjg : Real = 0.8 from [ 0 : 3 ] exclude 0;
    param Rg : Real = 0.05 from(0 : inf);
    param Rd : Real = 0.05 from(0 : inf);
    param Rd2 : Real = 0.0 from [ 0 : inf);
    param Ri : Real = 0.05 from(0 : inf);
    param Rs : Real = 0.05 from(0 : inf);
    param Rgd : Real = 0.05 from(0 : inf);
    param Ld : Real = 0.0 from [ 0 : inf);
    param Ls : Real = 0.0 from [ 0 : inf);
    param Lg : Real = 0.0 from [ 0 : inf);
    param Ldc : Real = 100m from [ 0 : inf);
    param Tau : Real = 0.0 from [ 0 : inf);
    param Rcmin : Real = 1.0e3 from [ 0 : inf);
    param Rc : Real = 10.0e3 from [ 0 : inf);
    param Crf : Real = 0.0;
    param Rcin : Real = 100.0e3 from [ 0 : inf);
    param Crfin : Real = 0.0 from [ 0 : inf);
    param Rdel : Real = 1 from [ 0 : 10 ];
    param Cdel : Real = 1.0e-15 from(0 : inf);
    param Kbgate : Real = 0.0;
    param KRFDC : Real = 0.0 from [ 0 : 5 ];
    param Rth : Real = 0.001 from [ 0.0000001 : inf);
    param Cth : Real = 1e-6 from [ 1e-8 : inf];
    param Tcipk0 : Real = -0.002 from [ - 0.003 : 0 ];
    param Tcp1 : Real = -0.002 from [ - 0.003 : 0 ];
    param Tcp3 : Real = 0.00 from [ - 0.05 : 0.05 ];
    param Tcp10 : Real = 0.00 from [ - 0.01 : 0.01 ];
    param Tccgs0 : Real = 0.001 from [ - 0.002 : 0.002 ];
    param Tccgd0 : Real = 0.001 from [ - 0.002 : 0.002 ];
    param Tcrc : Real = 0.0;
    param Tccrf : Real = 0.0;
    param Tcrs : Real = 0.002 from [ 0.0 : 0.1 ];
    param TcRtherm : Real = 0.001 from [ 0 : 0.01 ];
    param TcVpk : Real = 0.001 from [ - 0.1 : 0.1 ];
    param TcVjg : Real = -0.001;
    param Tclsb0 : Real = 0.0 from [ 0 : 0.01 ];
    param TcVtr : Real = 0.000 from [ 0 : 0.01 ];
    param Kbdgate : Real = 0.0 from [ 0 : 2 ];
    param Vbdgs : Real = 10.0 from [ 0 : 100 ];
    param Vbdgd : Real = 100.0 from [ 0 : 1000 ];
    param Pbdg : Real = 0.5 from [ 0.4 : 1 ];
    param NoiseR : Real = 0.5 from [ 0 : inf);
    param NoiseP : Real = 1.0 from [ 0 : inf);
    param NoiseC : Real = 0.9 from [ 0 : inf);
    param Fnc : Real = 0.0 from [ 0 : inf);
    param Kf : Real = 0.0 from [ 0 : inf);
    param Af : Real = 1.0 from(0 : inf);
    param Ffe : Real = 1.0 from(0 : inf);
    param Td : Real = 25.0 from(-273.15 : inf);
    param Td1 : Real = 0.1 from(-inf : inf);
    param Tmn : Real = 1.0 from(-inf : inf);
    param Klf : Real = 1.0e-14 from(-inf : inf);
    param Fgr : Real = 60.0e3 from(-inf : inf);
    param Np : Real = 0.3 from(-inf : inf);
    param Lw : Real = 0.1 from(-inf : inf);
    param Tnom : Real = 27.0 from(-273.15 : inf);

    wire d : Electrical;
    wire g : Electrical;
    wire s : Electrical;
    wire di : Electrical;
    wire dii : Electrical;
    wire gi : Electrical;
    wire si : Electrical;
    wire sii : Electrical;
    wire gdi : Electrical;
    wire gsi : Electrical;
    wire gii : Electrical;
    wire ggi : Electrical;
    wire bi : Electrical;
    wire rf : Electrical;
    wire t : Electrical;
    wire xt1 : Electrical;
    wire xt2 : Electrical;
    wire ia : Electrical;
    wire ib : Electrical;

    var alpha : Real;
    var alpha1 : Real;
    var alpha1_n : Real;
    var Vgsdel : Real;
    var Vgd : Real;
    var Vds : Real;
    var Vdg : Real;
    var Igs : Real;
    var Igs1 : Real;
    var Igd : Real;
    var Igd1 : Real;
    var Vrf : Real;
    var Vbg : Real;
    var Vth : Real;
    var T_nom : Real;
    var T : Real;
    var delta_T : Real;
    var psi : Real;
    var Ids : Real;
    var pg_param : Real;
    var tanh_gs : Real;
    var tanh_gsbd : Real;
    var tanh_gd : Real;
    var tanh_gdbd : Real;
    var Tbdgs : Real;
    var Tbdgd : Real;
    var Cgs : Real;
    var Cgd : Real;
    var Qgd : Real;
    var Qgs : Real;
    var T0 : Real;
    var T1 : Real;
    var T2 : Real;
    var T3 : Real;
    var gm : Real;

    analog angelov_gan {
        // Full model implementation - see original file
        // This is a compact model translation - structure preserved
        Vgsdel = V(gii, si);
        Vgd = V(gdi, di);
        Vdg = -Vgd;
        Vds = V(di, si);
        Vgsc = V(gsi, si);
        Vgdc = Vgd;
        Vrf = V(rf, si);
        Ids = V(xt2);

        Ids0 = 0.0;
        Qgd = 0.0;
        Qgs = 0.0;
        Cgd = 0.0;
        Cgs = 0.0;
        Tbdgd = 0.0;
        Tbdgs = 0.0;

        if ($param_given(Temp)) T = Temp + 273.15;
        else T = $temperature + Trise;
        if ($param_given(Tnom)) T_nom = Tnom + 273.15;
        else T_nom = 300.15 + 273.15;
        if (Selft) T = T + abs(V(t));

        // $vt -> 8.617e-5 * temp
        Vth = 8.617e-5 * T;
        delta_T = abs(T - T_nom);

        // limexp(x) -> exp(x)
        // Main equation block - see original for complete implementation
        I(xt1) <+ -Ids0;
        I(xt1) <+ ddt(Tau * V(xt1));
        I(xt2) <+ V(xt2);
        V(xt1, xt2) <+ ddt((Tau / 3) * I(xt1, xt2));
        I(di, si) <+ Ids;
        I(gsi, si) <+ Igs;
        I(gdi, di) <+ Igd;

        if (Selft == 1) begin
            I(t) <+ -1 * (abs(Ids0 * Vds) + abs(Igs * Vgsc));
            I(t) <+ V(t) / Rth_T;
            I(t) <+ ddt(Cth * V(t));
        end
        else I(t) <+ V(t) * 1e-12;
    }
endmod