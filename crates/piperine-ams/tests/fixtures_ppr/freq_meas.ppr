mod freq_meas(clk);
    input clk;
    var last_time : Real;
    var current_time : Real;
    var freq : Real;

    @ initial begin
        last_time = 0.0;
        freq = 0.0;
    end
    @ posedge clk begin
        current_time = $realtime;
        if (last_time > 0.0) freq = 1.0e9 / (current_time - last_time);
        last_time = current_time;
    end
endmod