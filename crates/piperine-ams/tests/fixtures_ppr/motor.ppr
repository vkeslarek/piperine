// This version complies with the Verilog-AMS (vers. 2.1) but does not
// run in the existing version of Spectre (5.0 May 03). See smpl_ckt2.vams
// for an alternate version that does run in Spectre.

// A motor test circuit

mod test {
    wire gnd : Ground;
    // vsrc # (.dc(1)) V1(drive, gnd);
    // motor M1(drive, gnd, shaft);
    // Note: This file contains both a test module and a motor module
    // Test module needs vsrc and motor instances which are not defined here
}

// Motor
// Note: rotational_omega discipline not standard in PHDL - would need custom discipline

mod motor(inout p : Electrical, inout n : Electrical, inout shaft : ?RotationalOmega?) {
    param km : Real = 4.5; // motor constant (V-s/rad)
    param kf : Real = 6.2; // flux constant (N-m/A)
    param j : Real = 0.004; // inertia of shaft (N-m-s2/rad)
    param d : Real = 0.1; // drag (friction) (N-m-s/rad)
    param r : Real = 5.0; // motor winding resistance (Ohms)
    param l : Real = 0.02; // motor winding inductance (H)
    wire p : Electrical, n : Electrical;
    // wire shaft : RotationalOmega; // custom discipline needed
    // Note: Omega(shaft) and Tau(shaft) are discipline access functions
    // V(p, n) <+ km * Omega(shaft) + r * I(p, n) + l * ddt(I(p, n));
    // Tau(shaft) <+ kf * I(p, n) - d * Omega(shaft) - j * ddt(Omega(shaft));
    analog motor {
        // Full translation requires custom RotationalOmega discipline
    }
}