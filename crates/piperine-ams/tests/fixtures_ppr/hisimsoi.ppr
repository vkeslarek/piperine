// HiSIM_SOI (Silicon-On-Insulator Model)
// Version 1.50
// Copyright 2000-2021 Hiroshima University and STARC
//
// Note: This is a highly complex SOI MOSFET model with many macros.
// Full translation requires extensive manual work.

mod hisimsoi_va(inout d : Electrical, inout g : Electrical, inout s : Electrical, inout e : Electrical, inout bc : Electrical, inout n6 : Electrical) {
    wire d : Electrical, g : Electrical, s : Electrical, e : Electrical, bc : Electrical, n6 : Electrical;
    wire dp : Electrical, sp : Electrical;
    wire db : Electrical, sb : Electrical;
    wire temp : Electrical, gp : Electrical, bp : Electrical;
    wire nqs_qb : Electrical, n : Electrical;
    wire nqs_qd : Electrical, nqs_qs : Electrical, nqs_qhs : Electrical;
    wire nqs_qi : Electrical;

    // Device type parameter
    param type : Integer = 1; // constraint: -1 <= type <= 1, type != 0

    // Basic geometry parameters
    param l : Real = 2.0e-6; // constraint: l > 0
    param w : Real = 10.0e-6; // constraint: w > 0

    // Temperature parameters
    param tnom : Real = 27.0; // constraint: tnom >= 0
    param dta : Real = 0.0;

    // Multiplicity factor
    param mult : Real = 1.0; // constraint: mult >= 1

    analog hisimsoi_va {
        // Behavioral code not directly translatable
    }
}