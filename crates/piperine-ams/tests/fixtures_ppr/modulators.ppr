// AM/PM/FM Modulators
//
// Version 1a
//

// AM Modulator
mod AMmodulator(inout out : Electrical, input in : Electrical) {
    param freq : Real = 1; // constraint: freq >= 0
    param mod_index : Real = 1;
    analog AMmodulator {
        // V(out) <+ (1 + mod_index * V(in)) * cos(2 * M_PI * freq * $abstime);
        // Note: $abstime not directly available in PHDL - would need abstime function
        // $bound_step(0.05 / freq) - step limiting not directly translatable
    }
}

// PM Modulator
mod PMmodulator(inout out : Electrical, input in : Electrical) {
    param freq : Real = 1; // constraint: freq >= 0
    param kp : Real = 1;
    analog PMmodulator {
        // V(out) <+ cos(2 * M_PI * freq * $abstime + kp * V(in));
    }
}

// FM Modulator
mod FMmodulator(inout out : Electrical, input in : Electrical) {
    param freq : Real = 1; // constraint: freq >= 0
    param fd : Real = 1;
    analog FMmodulator {
        // V(out) <+ cos(2 * M_PI * (freq * $abstime + idtmod(fd * V(in), 0, 1, -0.5)));
        // Note: idtmod() function not directly translatable to PHDL
    }
}