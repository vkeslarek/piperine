// Series RLC
//
// Version 1a, 1 June 04
//
// Ken Kundert
//
// Downloaded from The Designer's Guide Community (www.designers-guide.org).
// Post any questions on www.designers-guide.org/Forum.
// Taken from "The Designer's Guide to Verilog-AMS" by Kundert & Zinke.
// Chapter 3, Listing 14.

// `include "disciplines.vams"

mod series_rlc1 ( inout p : Electrical, inout n : Electrical ) {
    param r : Real = 0.0; // resistance (Ohms)
    param l : Real = 0.0; // inductance (H)
    param c : Real = 1p; // exclude 0 // capacitance (F)

    analog series_rlc1 {
        V(p, n) <+ r * I(p, n);
        V(p, n) <+ l * ddt(I(p, n));
        V(p, n) <+ idt(I(p, n)) / c;
    }
}

mod series_rlc2 ( inout p : Electrical, inout n : Electrical, inout i : Electrical ) {
    param r : Real = 0.0; // resistance (Ohms)
    param l : Real = 0.0; // inductance (H)
    param c : Real = 0.0; // capacitance (F)
    wire rl : Electrical;
    wire cap : Electrical;

    analog series_rlc2 {
        V(rl) <+ r * I(rl);
        V(rl) <+ l * ddt(I(rl));
        I(cap) <+ c * ddt(V(cap));
    }
}

endmodule