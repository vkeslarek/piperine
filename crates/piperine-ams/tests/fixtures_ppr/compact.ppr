// SPICE-specific different values:
param SPICE_GMIN : Real = 1.0e-12;
param SPICE_K : Real = 1.3806226e-23;
param SPICE_Q : Real = 1.6021918e-19;
param LARGE_REAL : Real = 1.0e38;
param MIN_CONDUCTANCE : Real = 1.0e-3;
param DEFAULT_TNOM : Real = 27;
/* NOT_GIVEN are codes that are used to detect if a
* parameter value has been passed (future extensions
* to Verilog-A should make this obsolete). */
param NOT_GIVEN : Real = -9.9999e-99;
param INT_NOT_GIVEN : Integer = -9999999;
param N_MINLOG : Real = 1.0e-38;
param MAX_EXP : Real = 5.834617425e14;
param MIN_EXP : Real = 1.713908431e-15;
param EXP_THRESHOLD : Real = 34.0;
param TRUE : Integer = 1;
param FALSE : Integer = 0;
/* Useful macro for setting Type
example: SET_TYPE(P_TYPE, N_TYPE, Type);
will set variable Type */
// Note: macro definitions not supported in PHDL