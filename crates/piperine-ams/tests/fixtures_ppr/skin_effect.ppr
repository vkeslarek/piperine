// Skin Effect Model
//
// Version 1a, 1 June 04
//
// Ken Kundert
//
// Downloaded from The Designer's Guide Community (www.designers-guide.org).
// Post any questions on www.designers-guide.org/Forum.
// Taken from "The Designer's Guide to Verilog-AMS" by Kundert & Zinke.
// Chapter 3, Listing 29.
//
// This version complies with the Verilog-AMS (vers. 2.1) but does not
// run in the existing version of Spectre (5.0 May 03). See skin_effect2.vams
// for an alternate version that does run in Spectre.

// `include "disciplines.vams"
// `include "constants.vams"

mod skin_effect ( inout p : Electrical, inout n : Electrical ) {
    param lumps : Integer = 10; // from(1:30] // number of lumps in approximation
    param f0 : Real = 1.0; // from(0:inf) // lower frequency bound (Hz)
    param f1 : Real = 10.0; // from(f0:inf) // upper frequency bound (Hz)
    param r0 : Real = 1.0; // from(0:inf) // DC series resistance (Ohms)

    var mult : Real;
    var mult2 : Real;
    var wp : Real;
    var wz : Real;
    var zeros : Real[0:2*lumps-1];
    var poles : Real[0:2*lumps-1];
    var i : Integer;

    analog skin_effect {
        @(initial) begin
            mult = pow(f1 / f0, 1.0 / (4.0 * real(lumps)));
            mult2 = mult * mult;
            wz = 2.0 * M_PI * mult * f0;
            wp = mult2 * wz;
            for (i = 0; i < lumps; i = i + 1) begin
                zeros[2*i] = -wz;
                zeros[2*i + 1] = 0.0;
                poles[2*i] = -wp;
                poles[2*i + 1] = 0.0;
                wz = mult2 * wp;
                wp = mult2 * wz;
            end
        end
        // NOTE: laplace_zp may not be directly supported
        V(p, n) <+ r0 * laplace_zp(I(p, n), zeros, poles);
    }
}

endmodule