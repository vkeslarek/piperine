// BSIM-IMG 102.9.6 released 08/24/2022
// BSIM Independent Multi-Gate Model (Verilog-A)
// Copyright 2022 University of California

mod bsimimg(d, fg, s, bg, t);
    wire d, fg, s, bg:Electrical;
    wire di, si, gi, ge, n:Electrical;
    wire t:Thermal;

    // Model parameters
    param:Natural SHMOD = 0 from [ 0 : 1];
    param:Natural RDSMOD = 0 from [ 0 : 2];
    param:Natural RGATEMOD = 0 from [ 0 : 1];

    // Instance parameters
    param:Real L = 1.0e-5 from [ 0 : inf);
    param:Real W = 1.0e-5 from [ 0 : inf);
    param:Real NF = 1 from [ 1 : inf);
    // ... (additional parameters)

    analog bsimimg {
        // BSIM-IMG model implementation
        // From bsimimg_body.include
    }
endmod