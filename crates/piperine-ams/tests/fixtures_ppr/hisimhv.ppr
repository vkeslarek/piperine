// HiSIM_HV (High-Voltage Model)
// Version 2.50
// Copyright 2000-2019 Hiroshima University and STARC
//
// Note: This is a highly complex high-voltage MOSFET model with many macros.
// Full translation requires extensive manual work.

mod hisimhv_va(inout d : Electrical, inout g : Electrical, inout s : Electrical, inout b : Electrical, inout sub : Electrical, inout temp : Electrical) {
    wire d : Electrical, g : Electrical, s : Electrical, b : Electrical, sub : Electrical, temp : Electrical;
    wire dp : Electrical, gp : Electrical, sp : Electrical, bp : Electrical;
    wire db : Electrical, sb : Electrical, qi : Electrical, qb : Electrical;
    wire qbd : Electrical;

    // Device type parameter
    param type : Integer = 1; // constraint: -1 <= type <= 1, type != 0

    // Basic geometry parameters
    param l : Real = 2.0e-6; // constraint: l > 0
    param w : Real = 10.0e-6; // constraint: w > 0

    // Temperature parameters
    param tnom : Real = 27.0; // constraint: tnom >= 0
    param dta : Real = 0.0;

    // Multiplicity factor
    param mult : Real = 1.0; // constraint: mult >= 1

    analog hisimhv_va {
        // Behavioral code not directly translatable
    }
}