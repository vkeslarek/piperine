// EKV3 Debug and Extraction Results
// Output of model parameters and simulation results for debugging
// Controlled by INFO_LEVEL parameter

begin : EXTRACTING_RESULTS
    if (INFO_LEVEL > 0.0) begin
        // Introduction header with model version and mode
        // GENERAL INFORMATION - device name, temperature, UT, TNOM
        // EXTERNAL BIAS - VGB, VGS, VDB, VDS, VSB
        // DEVICE GEOMETRY - Leff, Weff, etc.
        // MODEL PARAMETERS - TOX, COX, GAMMA, etc.
        // OPERATING POINT - Vth,Ids,gm,gds,etc.
        // CAPACITANCES - Cgg, Cgd, Cgs, etc.
        // NOISE - thermal and flicker noise
        // EDGE DEVICE - edge transistor parameters
        // EXTRINSIC - series resistances, overlap capacitances
        // DIODES - source/drain junction parameters
        // Y PARAMETERS - for AC analysis
        // END HEADER
    end
end

mod ekv3_extract_debug_include;
    // This is an include file - not a standalone module
    // Content should be inlined in ekv3.va
endmod