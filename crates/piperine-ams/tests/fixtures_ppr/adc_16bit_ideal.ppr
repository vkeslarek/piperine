// VerilogA for VerilogAmsLib, adc_16bit_ideal, veriloga

// `define NUM_ADC_BITS 16

mod adc_16bit_ideal(in, clk, out);
    param vref : Real = 1.0;
    param vlogic_high : Real = 5;
    param vlogic_low : Real = 0;
    param vtrans_clk : Real = 2.5;
    param tdel : Real = 3u from [ 0 : inf);
    param trise : Real = 1u from(0 : inf);
    param tfall : Real = 1u from(0 : inf);

    wire in : Electrical;
    wire clk : Electrical;
    var out : Electrical;

    var unconverted : Real;
    var halfref : Real;
    var out_val : Real[0 : 16 - 1];

    var i : Integer;
    var j : Integer;
    var digital : Integer;

    analog adc_16bit_ideal {
        @ (initial_step) begin
            halfref = vref / 2;
        end

        @ (cross(V(clk) - vtrans_clk, 1)) begin
            digital = integer((V(in) / vref) * (1 << 16));
            for (i = 0; i < 16; i = i + 1) begin
                if ((digital >> i) & 1) out_val[i] = vlogic_high;
                else out_val[i] = vlogic_low;
            end
        end

        for (j = 0; j < 16; j = j + 1) begin
            // assign the outputs
            // transition() limitation - ddt approximation or comment needed
            V(out[j]) <+ out_val[j];
        end
    }

endmod

// `undef NUM_ADC_BITS