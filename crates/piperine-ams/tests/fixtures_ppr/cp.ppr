// Charge Pump
//
// Version 1a, 1 June 04
//
// Olaf Zinke
//
// Downloaded from The Designer's Guide Community (www.designers-guide.org).
// Post any questions on www.designers-guide.org/Forum.
// Taken from "The Designer's Guide to Verilog-AMS" by Kundert & Zinke.
// Appendix A, Listing 6.

mod cp(pout, nout, inc, dec) {
    param cur : Real = 1m; // output current (A)
    input inc : Electrical, dec : Electrical;
    inout pout : Electrical, nout : Electrical;
    var out : Real;

    analog cp {
        @(initial_step) out = 0.0;

        if (dec && !inc) out = -cur;
        else if (!dec && inc) out = cur;
        else out = 0;

        I(pout, nout) <+ -out; // transition not fully supported
    }
}