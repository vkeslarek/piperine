// N-bit Digital to Analog Converter
//
// Version 1a, 1 June 04
//
// Ken Kundert
//
// Downloaded from The Designer's Guide Community (www.designers-guide.org).
// Post any questions on www.designers-guide.org/Forum.
// Taken from "The Designer's Guide to Verilog-AMS" by Kundert & Zinke.
// Chapter 3, Listing 27.
//
// This version of the DAC was modified to work in the existing
// version of Spectre (5.0 May 2003).

// Note: `define bits 8 is not standard PHDL - using param instead
param bits : Natural = 8; // resolution (bits)

mod dac(out, in, clk) {
    param fullscale : Real = 1.0; // output range is from 0 to fullscale (V)
    param td : Real = 0; // delay from clock edge to output (s)
    param tt : Real = 0; // transition time of output (s)
    param vdd : Real = 5.0; // voltage level of logic 1 (V)
    param thresh : Real = vdd / 2; // logic threshold level (V)
    param dir : Integer = 1 from [-1:1] exclude 0; // 1 for rising edges, -1 for falling
    output out : Voltage;
    input in[0:bits-1] : Voltage;
    input clk : Voltage;
    var aout : Real;
    var weight : Integer;
    var i : Integer;

    analog dac {
        @(cross(V(clk) - thresh, dir) or initial_step) begin
            aout = 0;
            weight = 2;
            // generate statement not fully supported - using for loop
            for (i = bits - 1; i >= 0; i = i - 1) begin
                if (V(in[i]) > thresh) begin
                    aout = aout + fullscale / weight;
                end
                weight = weight * 2;
            end
            V(out) <+ aout; // Simplified transition
        end
    }
}