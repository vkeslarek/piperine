// Voltage-dependent nonlinear capacitor for pn junction

mod NonlinearCapacitor(p, n);
    inout p, n;
    wire p, n : Electrical;

    param cap_coef6 : Real = 3.271E-15;
    param cap_coef5 : Real = 1.136E-13;
    param cap_coef4 : Real = 1.584E-12;
    param cap_coef3 : Real = 1.150E-11;
    param cap_coef2 : Real = 4.790E-11;
    param cap_coef1 : Real = 1.262E-10;
    param cap_coef0 : Real = 3.400E-10;
    var cap : Real;
    var q : Real;
    param length : Real = 50e-6;

    analog begin
        cap = cap_coef6 * V(p, n) * V(p, n) * V(p, n) * V(p, n) * V(p, n) * V(p, n) + cap_coef5 * V(p, n) * V(p, n) * V(p, n) * V(p, n) * V(p, n) + cap_coef4 * V(p, n) * V(p, n) * V(p, n) * V(p, n) + cap_coef3 * V(p, n) * V(p, n) * V(p, n) + cap_coef2 * V(p, n) * V(p, n) + cap_coef1 * V(p, n) + cap_coef0;
        q = length * cap * V(p, n);
        I(p, n) <+ ddt(q);
    end
endmod