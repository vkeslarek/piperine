// EKV3 Nature and Discipline Definitions
// Defines Current, Charge, Voltage, Flux natures and electrical, voltage, current disciplines
// In Piperine HDL, these are built-in, this file documents the mapping

mod ekv3_natures;
    // Current nature - units = "A", access = I, idt_nature = Charge
    // Charge nature - units = "coul", access = Q, ddt_nature = Current
    // Voltage nature - units = "V", access = V, idt_nature = Flux
    // Flux nature - units = "Wb", access = Phi, ddt_nature = Voltage
    // electrical discipline - potential Voltage, flow Current
    // voltage discipline - potential Voltage
    // current discipline - potential Current
endmod