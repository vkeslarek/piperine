//   Qucs compact phototransistor model
//   The structure and theoretical background to the phototransistor
//   Verilog-A model are given in the COMON meeting demonstration
//   at link http://www.mos-ak.org/frankfurt_o/papers/M_Brinson_Qucs_COMON_April_2_2009_final.pdf.
//
//   This is free software; you can redistribute it and/or modify
//   it under the terms of the GNU General Public License as published by
//   the Free Software Foundation; either version 2, or (at your option)
//   any later version.
//
//   Copyright (C), Mike Brinson, mbrin72043@yahoo.co.uk, March 2009.
//
mod phototransistor(Collector, Base, Emitter, LightPower, Wavelength);
    inout Collector, Base, Emitter, LightPower, Wavelength;
    wire Collector : Electrical, Base : Electrical, Emitter : Electrical, LightPower : Electrical, Wavelength : Electrical;
    wire CI : Electrical, BI : Electrical, BI2 : Electrical, EI : Electrical;
    //
    // desc = "forward beta"
    param Bf : Real = 100.0 from [ 1.0 : inf );
    // desc = "reverse beta"
    param Br : Real = 0.1 from [ 1e-6 : inf ];
    // desc = "dark current", unit = "A"
    param Is : Real = 1e-10 from [ 1e-30 : inf ];
    // desc = "forward emission coefficient"
    param Nf : Real = 1.0 from [ 1e-30 : inf ];
    // desc = "reverse emission coefficient"
    param Nr : Real = 1.0 from [ 1e-30 : inf ];
    // desc = "forward early voltage", unit = "V"
    param Vaf : Real = 100.0 from [ 1e-6 : inf ];
    // desc = "reverse early voltage", unit = "V"
    param Var : Real = 100.0 from [ 1e-6 : inf ];
    // desc = "base-emitter junction exponential factor"
    param Mje : Real = 0.33 from [ 1e-6 : inf ];
    // desc = "base-emitter junction built-in potential", unit = "V"
    param Vje : Real = 0.75 from [ 1e-6 : inf ];
    // desc = "base-emitter zero-bias depletion capacitance", unit = "F"
    param Cje : Real = 1e-12 from [ 0.0 : inf ];
    // desc = "base-collector junction exponential factor"
    param Mjc : Real = 0.33 from [ 1e-6 : inf ];
    // desc = "base-collector junction built-in potential", unit = "V"
    param Vjc : Real = 0.75 from [ 1e-6 : inf ];
    // desc = "base-collector zero-bias depletion capacitance", unit = "F"
    param Cjc : Real = 2e-12 from [ 0.0 : inf ];
    // desc = "ideal reverse transit time", unit = "s"
    param Tr : Real = 100n from [ 1e-15 : inf ];
    // desc = "ideal forward transit time", unit = "s"
    param Tf : Real = 0.1n from [ 1e-15 : inf ];
    // desc = "high current corner for forward beta", unit = "A"
    param Ikf : Real = 10.0 from [ 1e-20 : inf ];
    // desc = "high current corner for reverse beta", unit = "A"
    param Ikr : Real = 10.0 from [ 1e-20 : inf ];
    // desc = "collector series resistance", unit = "Ohm"
    param Rc : Real = 10.0 from [ 1e-9 : inf ];
    // desc = "emitter series resistance", unit = "Ohm"
    param Re : Real = 1.0 from [ 1e-9 : inf ];
    // desc = "base series resistance", unit = "Ohm"
    param Rb : Real = 100.0 from [ 1e-9 : inf ];
    // desc = "flicker noise coefficient"
    param Kf : Real = 1e-12 from [ 0.0 : inf ];
    // desc = "flicker noise coefficient"
    param Ffe : Real = 1.0 from [ 0.0 : inf ];
    // desc = "flicker noise exponent"
    param Af : Real = 1.0 from [ 0.0 : inf ];
    // desc = "responsivity at relative selectivity=100%", unit = "A/W"
    param Responsivity : Real = 1.5 from [ 1e-30 : inf ];
    // desc = "relative selectivity polynomial coefficient"
    param P0 : Real = 2.6122e3 from ( -inf : inf );
    // desc = "relative selectivity polynomial coefficient"
    param P1 : Real = -1.489e1 from ( -inf : inf );
    // desc = "relative selectivity polynomial coefficient"
    param P2 : Real = 3.0332e-2 from ( -inf : inf );
    // desc = "relative selectivity polynomial coefficient"
    param P3 : Real = -2.5708e-5 from ( -inf : inf );
    // desc = "relative selectivity polynomial coefficient"
    param P4 : Real = 7.6923e-9 from ( -inf : inf );
    //
    var VT : Real, con1 : Real, con2 : Real, con3 : Real, con4 : Real, con5 : Real, con6 : Real, con7 : Real, con8 : Real, con9 : Real, con10 : Real;
    var TwoQ : Real, FourKT : Real;
    var ICC : Real, IEC : Real, q1 : Real, q2 : Real, IB : Real, IC : Real, IE : Real, Q1 : Real, RelSensitivity : Real;
    //
    analog SpicePhototransistor {
        @ initial {
            VT = 8.617e-5 * 300.0;  // VT = vt(300)
            con1 = 1.0 / (Nf * VT);
            con2 = 1.0 / (Nr * VT);
            con3 = 1.0 - Mje;
            con4 = 1.0 - Mjc;
            con5 = pow(2.0, Mje);
            con6 = pow(2.0, Mjc);
            con7 = Rb / 2.0;
            con8 = 2.0 / Rb;
            con9 = 1.0 / Rc;
            con10 = 1.0 / Re;
            TwoQ = 2.0 * 1.602176565e-19;  // TwoQ = 2*q
            FourKT = 4.0 * 1.3806488e-23 * temp;  // FourKT = 4*K*T
            //            GMIN=1e-12;
        }
        // Model quantity equations and current contributions
        ICC = Is * (exp(V(BI, EI) * con1) - 1.0);
        IEC = Is * (exp(V(BI, CI) * con2) - 1.0);
        q1 = 1.0 + V(BI, CI) / Vaf + V(BI, EI) / Var;
        q2 = (ICC / Ikf) + (IEC / Ikr);
        IB = V(BI2, BI) * con8;
        IC = V(Collector, CI) * con9;
        IE = V(EI, Emitter) * con10;
        I(Collector, CI) <+ IC;
        I(Base, BI2) <+ V(Base, BI2) * con8;
        I(BI2, BI) <+ IB;
        I(EI, Emitter) <+ IE;
        I(BI, CI) <+ (IEC / Br) + 1e-12 * V(BI, CI);
        I(BI, EI) <+ (ICC / Bf) + 1e-12 * V(BI, EI);
        I(CI, EI) <+ (ICC - IEC) / (1e-20 + (q1 / 2.0) * (1.0 + sqrt(1.0 + 4.0 * q2)));
        Q1 = (V(BI, CI) > Vjc / 2.0) ? Tr * IEC + Cjc * con6 * (Mjc * V(BI, CI) * V(BI, CI) / Vjc + con4 * V(BI, CI)) : Tr * IEC + Cjc * ((Vjc / con4) * (1.0 - pow((1.0 - V(BI, CI)), con4)));
        I(BI, CI) <+ ddt(Q1);
        Q1 = (V(BI, EI) > Vje / 2.0) ? Tf * ICC + Cje * con5 * (Mje * V(BI, EI) * V(BI, EI) / Vje + con3 * V(BI, EI)) : Tf * ICC + Cje * ((Vje / con3) * (1.0 - pow((1.0 - V(BI, EI)), con3)));
        I(BI, EI) <+ ddt(Q1);
        RelSensitivity = P0 + P1 * V(Wavelength) + P2 * pow(V(Wavelength), 2.0) + P3 * pow(V(Wavelength), 3.0) + P4 * pow(V(Wavelength), 4.0);
        I(CI, BI2) <+ ((Responsivity * RelSensitivity) / (Bf * 100.0)) * V(LightPower);
        // Noise contributions
        I(Collector, CI) <+ white_noise(FourKT * con9, "thermal");
        I(Base, BI2) <+ white_noise(FourKT * con8, "thermal");
        I(BI2, BI) <+ white_noise(FourKT * con8, "thermal");
        I(EI, Emitter) <+ white_noise(FourKT * con10, "thermal");
        I(CI, EI) <+ white_noise(TwoQ * IC, "shot");
        I(BI, EI) <+ white_noise(TwoQ * IB, "shot");
        I(BI, EI) <+ flicker_noise(Kf * pow(IB, Af), Ffe, "flicker");
    }
endmod