/* Verilog-A large-signal model for a fixed-fixed beam RF MEMS capacitive switch, switched capacitor and varactor.
Content of RF_MEMS_CAPACITOR.va. Open-source code covered by BSD license.

The Verilog-A large signal model can be used for operating point, small signal (AC, SP)
and large signal (HB, PSS, QPSS) simulations, using ADS, SpectreRF or Qucs. It includes
large-signal electromechanical effects, as well as small-signal Brownian noise. It does
not include electro-thermal effects yet.

Electromechanical: C-V hysteresis, hold-down, self-actuation,
displacement-compensated squeeze-film damping
Noise: Brownian noise

5th of September, 2011
Check for update: http://www-personal.umich.edu/~vcaeken

Reference: "Modeling RF MEMS Devices", by K. Van Caekenberghe,
IEEE Microwave Magazine, vol. 13, no. 1, pp. 83-110, Jan.-Feb. 2012 */

// `include "disciplines.vams"
// `include "constants.vams"

mod RF_MEMS_CAPACITOR ( inout in : Electrical, inout out : Electrical ) {
    // Dimensions
    param g_0 : Real = 2e-6; // from(0:inf) // nominal gap height [m]
    param l : Real = 300e-6; // from(0:inf) // beam length [m]
    param t : Real = 0.5e-6; // from(0:inf) // beam thickness [m]
    param t_d : Real = 0.2e-6; // from[0:inf) // dielectric thickness [m]
    param w : Real = 80e-6; // from(0:inf) // beam width [m]
    param W : Real = 100e-6; // from(0:inf) // electrode width [m]
    // Material parameters: beam (gold)
    param nu : Real = 0.44; // from[0:inf) // Poisson ratio []
    param rho : Real = 19.2e3; // from(0:inf) // mass density [kg/m^3]
    param sigma : Real = 100e6; // from[0:inf) // residual stres [Pa]
    param E : Real = 78e9; // from(0:inf) // Young's modulus [Pa]
    // Material parameters: dielectric (silicon nitride)
    param epsilon_r : Real = 7.6; // from[1:inf) // dielectric constant []
    // Material parameters: gas (air):
    param lambda : Real = 1.5e-7; // from[0:inf) // mean-free path [m]
    param mu : Real = 1.845e-5; // from(0:inf) // viscosity coefficient [kg/(m.s)]
    // van der Waals and nuclear force coefficients
    param c_1 : Real = 10e-80; // from[0:inf) // van der Waals force coefficient [N.m]
    param c_2 : Real = 10e-75; // from[0:inf) // nuclear force coefficient [N.m^8]

    wire z : Kinematic;
    wire velocity : Kinematic;

    var A : Real;
    var b : Real;
    var C : Real;
    var C_d : Real;
    var C_u : Real;
    var F_c : Real;
    var F_e : Real;
    var F_s : Real;
    var f_m_0 : Real;
    var IIP3 : Real;
    var k_1 : Real;
    var k_3 : Real;
    var m : Real;
    var Q_e : Real;
    var Q_m : Real;
    var t_s_max : Real;
    var t_s_min : Real;
    var V_H : Real;
    var V_P : Real;
    var V_S : Real;

    analog RF_MEMS_CAPACITOR {

        @(initial) begin
            A = W * w;
            // NOTE: $strobe not supported - use $info or comment
            m = 0.4 * rho * l * t * w;
            k_1 = 32.0 * E * w * pow(t / l, 3.0) * 27.0 / 49.0 + 8.0 * sigma * (1.0 - nu) * w * t / l * 3.0 / 5.0;
            k_3 = pow(M_PI, 4.0) * E * w * t / (8.0 * pow(l, 3.0));
            V_H = sqrt(2.0 * k_1 * g_0 * pow(t_d / epsilon_r, 2.0) / (P_EPS0 * epsilon_r * A));
            V_P = sqrt(8.0 * k_1 * pow(g_0 + t_d / epsilon_r, 3.0) / (27.0 * A * P_EPS0));
            f_m_0 = sqrt(k_1 / m) / (2.0 * M_PI);
            Q_m = sqrt(E * rho) * pow(t, 2.0) * pow(g_0, 3.0) / (mu * pow(w * l / 2.0, 2.0));
            V_S = V_P;
            t_s_max = 27.0 * pow(V_P, 2.0) / (4.0 * 2.0 * M_PI * f_m_0 * Q_m * pow(V_S, 2.0));
            t_s_min = 3.67 * V_P / (V_S * sqrt(k_1 / m));
            C_u = P_EPS0 * A / (g_0 + t_d / epsilon_r);
            C_d = P_EPS0 * A / (t_d / epsilon_r);
            IIP3 = 10.0 * log(2.0 * k_1 * pow(g_0, 2.0) / (M_PI * 10e9 * pow(C_u * 50.0, 2.0))) + 30.0;
        end

        // b: damping coefficient [N.s/m] (displacement-compensated squeeze-film damping)
        // NOTE: tanh, Pos() functions may not be directly available
        Q_e = Q_m * pow(1.1 - pow(g_0 * tanh(Pos(z) / g_0) / g_0, 2.0), 1.5) * (1.0 + 9.9638 * pow(lambda / (g_0 - g_0 * tanh(Pos(z) / g_0)), 1.159));
        b = k_1 / (2.0 * M_PI * f_m_0 * Q_e);

        // Forces
        // NOTE: van der Waals and nuclear force calculation
        F_c = c_1 * A / pow(g_0 - g_0 * tanh(Pos(z) / g_0) + 1e-9, 3.0) - c_2 * A / pow(g_0 - g_0 * tanh(Pos(z) / g_0) + 1e-9, 10.0);
        F_e = P_EPS0 * A * pow(V(out, in), 2.0) / 2.0 / pow(g_0 + t_d / epsilon_r - Pos(z), 2.0);
        F_s = k_1 * Pos(z) + k_3 * pow(Pos(z), 3.0);

        // Nonlinear time-varying state-space description
        // NOTE: ddt and special discipline operators may not map directly
        Pos(velocity) : ddt(Pos(z)) == Pos(velocity);
        Pos(z) : ddt(Pos(velocity)) == 1.0 / m * (-b * Pos(velocity) - F_s + F_e + F_c + white_noise(4.0 * P_K * $temperature * b, "BROWNIAN_NOISE"));

        if (Pos(z) < g_0) {
            C = P_EPS0 * A / (g_0 + t_d / epsilon_r - Pos(z));
        } else {
            C = C_d;
        }

        I(out, in) <+ ddt(C * V(out, in));

    }
}

endmodule