// Junction diode
//
// Version 1a, 1 June 04
//
// Ken Kundert
//
// Downloaded from The Designer's Guide Community (www.designers-guide.org).
// Post any questions on www.designers-guide.org/Forum.
// Taken from "The Designer's Guide to Verilog-AMS" by Kundert & Zinke.
// Chapter 3, Listing 11.

mod diode(a, c);
    param:Real is = 10f from(0 : inf);
    // saturation current (A)
    param:Real tf = 0 from [ 0 : inf);
    // forward transit time (s)
    param:Real cjo = 0 from [ 0 : inf);
    // zero-bias junction capacitance (F)
    param:Real phi = 0.7 exclude 0;
    // built-in junction potential (V)
    wire a, c:Electrical;
    wire res, cap:Electrical;
    var qd;

    analog diode {
        I(res) <+ is * (exp(V(res) / (8.617e-5*temp)) - 1);
        qd = tf * I(res) - 2 * cjo * phi * sqrt(1 - V(cap) / phi);
        I(cap) <+ ddt(qd);
    }
endmod