// `include "constants.vams"
// `include "disciplines.vams"

// Optical two-by-one combiner

mod TwoOneCombiner ( inout [0:3] two1 : Optical, inout [0:3] two2 : Optical, inout [0:3] one : Optical ) {
    param kappa : Real = 0.5; // Power ratio

    analog TwoOneCombiner {
        OptE(one[0]) <+ OptE(two1[0]) * sqrt(kappa) + OptE(two2[0]) * sqrt(1.0 - kappa);
        OptE(one[1]) <+ OptE(two1[1]) * sqrt(kappa) + OptE(two2[1]) * sqrt(1.0 - kappa);
        OptE(two1[2]) <+ sqrt(kappa) * OptE(one[2]);
        OptE(two1[3]) <+ sqrt(kappa) * OptE(one[3]);
        OptE(two2[2]) <+ sqrt(1.0 - kappa) * OptE(one[2]);
        OptE(two2[3]) <+ sqrt(1.0 - kappa) * OptE(one[3]);
    }
}

endmodule