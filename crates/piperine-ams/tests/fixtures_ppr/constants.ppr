// Mathematical and physical constants

param M_E : Real = 2.7182818284590452354;
param M_LOG2E : Real = 1.4426950408889634074;
param M_LOG10E : Real = 0.43429448190325182765;
param M_LN2 : Real = 0.69314718055994530942;
param M_LN10 : Real = 2.30258509299404568402;
param M_PI : Real = 3.14159265358979323846;
param M_TWO_PI : Real = 6.28318530717958647693;
param M_PI_2 : Real = 1.57079632679489661923;
param M_PI_4 : Real = 0.78539816339744830962;
param M_1_PI : Real = 0.31830988618379067154;
param M_2_PI : Real = 0.63661977236758134308;
param M_2_SQRTPI : Real = 1.12837916709551257390;
param M_SQRT2 : Real = 1.41421356237309504880;
param M_SQRT1_2 : Real = 0.70710678118654752440;

// Physical constants from NIST
param P_Q : Real = 1.602176462e-19; // charge of electron in Coulombs
param P_C : Real = 2.99792458e8; // speed of light in vacuum in meters/second
param P_K : Real = 1.3806503e-23; // Boltzmann's constant in Joules/Kelvin
param P_H : Real = 6.62606876e-34; // Planck's constant in Joules*second
param P_EPS0 : Real = 8.854187817e-12; // permittivity of vacuum in Farads/meter
param P_U0 : Real = 4.0e-7 * M_PI; // permeability of vacuum in Henrys/meter
param P_CELSIUS0 : Real = 273.15; // zero Celsius in Kelvin