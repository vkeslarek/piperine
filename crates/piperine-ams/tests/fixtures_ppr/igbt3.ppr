// IGBT Verilog-A model
//
// based upon Allen R. Hefner and Daniel M. Diebold's model for IGBTs
//
// Hefner, A.R. and Diebolt, D.M. An experimentally verified IGBT model implemented
// in the Saber circuit simulator. PESC '91 Record 22nd Annual IEEE Power Electronics Specialists Conference
// (24-27 June 1991): https://ieeexplore.ieee.org/document/162645
//
// Allen R. Hefner, Jr. A Dynamic Electro-Thermal Model for the IGBT, November 16, 1992
//
// Matlab implementation:
// https://de.mathworks.com/help/sps/ref/spicenigbt.html
//
// This is free software; you can redistribute it and/or modify
// it under the terms of the GNU General Public License as published by
// the Free Software Foundation; either version 2, or (at your option)
// any later version.
//
// Copyright (C) 2009 Stefan Jahn <stefan@lkcc.org>
// Modified 2023 Dietmar Warning https://github.com/dwarning/VA-Models
//

// Note: Complex IGBT model with many implicit variables and system branches
// Many $limit() calls and iterative solve blocks not directly translatable

mod igbt3(inout a : Electrical, inout g : Electrical, inout c : Electrical) {
    wire a : Electrical, g : Electrical, c : Electrical;
    wire e : Electrical, b : Electrical;
    wire var_Qeb : Electrical, var_Mucinv : Electrical, var_Nsat : Electrical;

    wire b_gc : Electrical, b_bg : Electrical, b_bc : Electrical;
    wire b_ec : Electrical, b_eb : Electrical, b_ae : Electrical;
    wire b_Qeb : Electrical, b_Mucinv : Electrical, b_Nsat : Electrical;

    param Agd : Real = 5e-6; // constraint: Agd > 0 ("m**2", "gate-drain overlap area")
    param Area : Real = 1e-5; // constraint: Area > 0 ("m**2", "area of the device")
    param Kp : Real = 0.38; // constraint: Kp > 0 ("A/V**2", "MOS transconductance")
    param Tau : Real = 7.1e-6; // constraint: Tau > 0 ("s", "ambipolar recombination lifetime")
    param Wb : Real = 9e-5; // constraint: Wb > 0 ("m", "metallurgical base width")

    param BVf : Real = 1.0; // constraint: BVf > 0 ("", "avalanche uniformity factor")
    param BVn : Real = 4.0; // constraint: BVn > 0 ("", "avalanche multiplication exponent")
    param Cgs : Real = 1.24e-8; // constraint: Cgs >= 0 ("F/cm**2", "gate-source capacitance")
    param Coxd : Real = 3.5e-8; // constraint: Coxd >= 0 ("F/cm**2", "gate-drain oxide capacitance")
    param Jsne : Real = 6.5e-13; // constraint: Jsne >= 0 ("A/cm**2", "emitter saturation current density")
    param Kf : Real = 1.0; // constraint: Kf > 0 ("", "triode region factor")
    param Mun : Real = 1500; // constraint: Mun > 0 ("cm**2/Vs", "electron mobility")
    param Mup : Real = 450; // constraint: Mup > 0 ("cm**2/Vs", "hole mobility")
    param Nb : Real = 2.0e14; // constraint: Nb >= 0 ("1/cm**3", "base doping")
    param Theta : Real = 0.02; // constraint: Theta >= 0 ("1/V", "transverse field factor")
    param Vt : Real = 4.7; // constraint: Vt > 0 ("V", "threshold voltage")
    param Vtd : Real = 1.0e-3; // constraint: any ("V", "gate-drain overlap depletion threshold")
    param Tnom : Real = 27.0; // constraint: Tnom > -273.15 ("Celsius", "parameter measurement temperature")

    param Tau1 : Real = 1.5; // constraint: Tau1 > 0 ("", "Tau temperature exponent")
    param Isne1 : Real = 0.5; // constraint: Isne1 > 0 ("", "Jsne temperature exponent")
    param Vt1 : Real = -0.9e-3; // constraint: any ("V/K", "Vt temperature coefficient")
    param Kp1 : Real = 0.8; // constraint: Kp1 > 0 ("", "Kp temperature exponent")

    var Imos : Real, It : Real, Icss : Real, Imult : Real, Igen : Real, Ic : Real, Ibss : Real;
    var Rb : Real, B : Real, Dp : Real, L : Real, W : Real, M : Real;
    var Vds : Real, Vgs : Real, Vec : Real, Veb : Real, Vdg : Real, Vgeff : Real, Vbc : Real, Vebj : Real, Vebd : Real, Vebq : Real, Vae : Real;
    var Nsat : Real, Nscl : Real, Neff : Real;
    var Wbcj : Real, Wgdj : Real, Wdsj : Real;
    var Dc : Real, Qeb : Real, QString : Real, Qgd : Real, Qds : Real, Qcer : Real, Qmult : Real, Qb : Real, Qbi : Real;
    var Ccer : Real, Cbcj : Real, Cgdj : Real, Cgd : Real;
    var Mucinv : Real, Munc : Real, Mupc : Real, Mueff : Real, BVcbo : Real, P0 : Real, Deltap : Real;
    var WL : Real, WL2 : Real, Tanh_WL2 : Real, Ads : Real;
    var Ni : Real, Vpsat : Real, Vnsat : Real, Alpha1 : Real, Alpha2 : Real;
    var TauT : Real, IsneT : Real, VtT : Real, KpT : Real;

    var iQeb : Real, iMucinv : Real, iNsat : Real;

    var Vbi : Real, vt : Real;

    var P0_Qeb : Real, Vebj_Qeb : Real, T1 : Real, Vebd1 : Real, Vebd1_Qeb : Real, Vebd2 : Real, Vebd2_Qeb : Real, Vebd_Qeb : Real, Vebq_Qeb : Real;
    var l_it : Integer;
    var dV : Real, d_Q : Real, d_Q_max : Real;

    var ccsflg : Integer, sclflg : Integer;
    var Area_cm2 : Real, Agd_cm2 : Real, Wb_cm : Real;

    // Note: $limit() function calls, implicit iteration variables, and system branch
    // equations with ddt() contribute to a complex implicit system that cannot be
    // directly translated to PHDL's analog block format.
    analog igbt3 {
        // @ initial_instance { ... }
        // Initialization block with iterative solve and $limit() calls
        // Complex behavioral translation required
    }
}