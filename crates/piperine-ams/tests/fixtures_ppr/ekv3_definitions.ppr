// EKV3 Definitions - Physical Constants and Helper Functions
// Translated from Verilog-AMS to Piperine HDL

const TAD = 0.1E-9;

// Physical Constants
// Silicon Electrical Permittivity [F/m]
const C_EPSSIL = 1.03594314E-10;
// Oxide Electrical Permittivity [F/m]
const C_EPSOX = 34.53144E-12;
// Electron Charge [C]
const C_QE = 1.602E-19;
// Boltzmann constant [J/K]
const C_K = 1.3807E-23;

// zero Celsius in Kelvin
const P_CELSIUS0 = 273.15;

// Thermal Potential, as a function of temperature (T) in K.
function UT(T) = (C_K * T) / C_QE;

// Frequently Used Numbers
const SQRT2 = 1.4142135623730950488016887242097;
const ONE3RD = 0.33333333333333333333333333333333;
const TWO3RDS = 0.66666666666666666666666666666667;
const ONESQRT2 = 0.70710678118654752440084436210485;
const PI = 3.1415926535897932384626433832795;

// Small Positive Number
const POS_MIN = 1.0E-6;
// The minimum value of a resistance.
const MINIMUM_RESISTANCE = 1.0E-3;

// Useful mathematical functions
function MAX(x, y) = (x > y ? x : y);
function MIN(x, y) = (x < y ? x : y);
function MIN_MAX(val, min, max) = MIN(MAX(val, min), max);
function MAXA(x, y, a) = 0.5 * ((x) + (y) + sqrt(((x) - (y)) * ((x) - (y)) + (a)));
function MINA(x, y, a) = 0.5 * ((x) + (y) - sqrt(((x) - (y)) * ((x) - (y)) + (a)));
function MINA_MAXA(val, min, max, a) = MINA(MAXA(val, min, a), max, a);

// Used for limiting exponent by analog function lexp
const EXPL_THRESHOLD = 80.0;
const MAX_EXPL = 5.540622384e+34;
const MIN_EXPL = 1.804851387e-35;