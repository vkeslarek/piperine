// Enhanced Electrical to Logic Connect Module
//
// Version 1a, 1 June 04
//
// Olaf Zinke
//
// Downloaded from The Designer's Guide Community (www.designers-guide.org).
// Post any questions on www.designers-guide.org/Forum.
// Taken from "The Designer's Guide to Verilog-AMS" by Kundert & Zinke.
// Chapter 4, Listing 17.

// mod a2d(out, in);
// Note: connectmodule translated as mod with note
mod a2d(out, in);
    // minimum voltage of a logic 1 (V)
    param vh : Real = 2.7;
    // maximum voltage of a logic 0 (V)
    param vl : Real = 0.5;
    // input capacitance (F)
    param c : Real = 100f;
    // time in x region before x is produced (s)
    param dt : Real = 1n;
    // voltage between threshold and x region (V)
    param dv : Real = 0.2;

    wire in : Electrical;
    var out : Logic;

    param vlx : Real = vl + dv;
    param vhx : Real = vh - dv;
    var inXregion : Logic;

    @ initial {
        inXregion = 0;
    }

    @ cross(V(in) - vh) {
        out = 1'b1;
        inXregion = 0;
    }

    @ cross(vl - V(in)) {
        out = 1'b0;
        inXregion = 0;
    }

    @ cross(vhx - V(in)) inXregion = 1;
    @ cross(V(in) - vlx) inXregion = 1;

    @ posedge(inXregion) {
        // XRegionDelay # (dt / 1.0n) // calculate how many time units are equal to the dt time
        out = 1'bx;
        inXregion = 0;
    }
    @ negedge(inXregion) disable XRegionDelay;

    analog a2d {
        I(in) <+ c * ddt(V(in));
    }
endmod