// Shunt RLC
//
// Version 1a, 1 June 04
//
// Ken Kundert
//
// Downloaded from The Designer's Guide Community (www.designers-guide.org).
// Post any questions on www.designers-guide.org/Forum.
// Taken from "The Designer's Guide to Verilog-AMS" by Kundert & Zinke.
// Chapter 3, Listing 15.

// `include "disciplines.vams"

mod shunt_rlc1 ( inout p : Electrical, inout n : Electrical ) {
    param r : Real = 1.0; // exclude 0 // resistance (Ohms)
    param l : Real = 1n; // exclude 0 // inductance (H)
    param c : Real = 0.0; // capacitance (F)

    analog shunt_rlc1 {
        I(p, n) <+ V(p, n) / r;
        I(p, n) <+ c * ddt(V(p, n));
        I(p, n) <+ idt(V(p, n)) / l;
    }
}

mod shunt_rlc2 ( inout p : Electrical, inout n : Electrical ) {
    param r : Real = 0.0; // resistance (Ohms)
    param l : Real = 0.0; // inductance (H)
    param c : Real = 0.0; // capacitance (F)
    wire res : Electrical;
    wire cap : Electrical;
    wire ind : Electrical;

    analog shunt_rlc2 {
        V(res) <+ r * I(res);
        I(cap) <+ c * ddt(V(cap));
        V(ind) <+ l * ddt(I(ind));
    }
}

endmodule