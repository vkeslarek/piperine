// Varactor Model
//
// Version 1b, 23 October 2006
//
// Ken Kundert
//
// downloaded from the designer's guide (www.designers-guide.org).
// post any questions on www.designers-guide.org/forum.
// Documentation on the model can be found at www.designers-guide.org/Modeling

// `include "disciplines.vams"

mod varactor ( inout p : Electrical, inout n : Electrical ) {
    param c0 : Real = 1p; // from(0:inf) // nominal capacitance (F)
    param c1 : Real = 0.5p; // from[0:c0) // maximum capacitance change from nominal (F)
    param v0 : Real = 0.0; // voltage for nominal capacitance (V)
    param v1 : Real = 1.0; // from(0:inf) // voltage change for maximum capacitance (V)

    var q : Real;
    var v : Real;

    analog varactor {
        v = V(p, n);
        q = c0 * v + c1 * v1 * ln(cosh((v - v0) / v1));
        I(p, n) <+ ddt(q);
    }
}

endmodule