mod DIODE_CMC(A, K);
    wire A, K:Electrical;
    wire AIK, charge_A, charge_K, depl_A:Electrical;

    param:Real LEVEL = 2002;
    param:Real VERSION = 2;
    param:Real SUBVERSION = 0;
    param:Real REVISION = 0;
    param:Real TYPE = 1 from [ -1.0 : 1.0 ];
    param:Real DTA = 0;

    // Instance parameters
    param:Real AB = 1E-12 from [ 0 : inf);
    param:Real LS = 1e-6 from [ 0 : inf);
    param:Real LG = 0 from [ 0 : inf);
    param:Real MULT = 1 from [ 0 : inf);

    // Alias parameters
    // AREA = AB, PERIM = LS, PJ = LS, PT = XTI

    var MULT_i;
    var EPSSI;
    // ... (additional variables from include files)

    analog DIODE_CMC {
        // Initialization
        // Junction current and charge calculations
        // Recovery charge modeling
        // High-injection effects
        // Noise contributions
        // ddt() contributions
        // Operating point info
    }
endmod