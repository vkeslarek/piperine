// VerilogA for VerilogAmsLib, amp_dynamic, veriloga
// Translated from amp_dynamic.va
// Note: transition() function has limited support in PHDL

mod amp_dynamic (
    input clk,
    input rst,
    input inp,
    input inm,
    output done,
    output outp,
    output outm,
)
{
    // Amplification time (s)
    param tamp : Real = 10e-6;
    // Gain (V/V)
    param gain : Real = 8.0;
    // Common mode output voltage (V)
    param vcm : Real = 2.5;
    // Input referred offset (V)
    param offset : Real = 0.0;
    // Logic high voltage (V)
    param vlogic_high : Real = 5.0;
    // Transition voltage (V)
    param vtrans : Real = 2.5;
    // Delay time (s) - from [0 : inf)
    param tdel : Real = 3e-6;
    // Rise time (s) - from(0 : inf)
    param trise : Real = 1e-6;
    // Fall time (s) - from(0 : inf)
    param tfall : Real = 1e-6;

    wire clk_d : Electrical;
    wire outp_pre : Electrical;
    wire outm_pre : Electrical;

    var outDiff : Real;
    var outp_val : Real;
    var outm_val : Real;
    var done_val : Real = 1.0;

    // NOTE: transition() is simplified - PHDL uses ddt-based smoothing
    analog amp_dynamic {
        @ initial {
            done_val = 1.0;
        }

        // Delayed clock generation
        // transition(V(clk), tamp + 2*tdel, trise, tfall) -> simplified
        V(clk_d) <+ V(clk);

        // Amplification start on rising clock edge
        @ cross(V(clk) - vtrans, +1) {
            done_val = 0.0;
            outDiff = (V(inp) - V(inm) + offset) * gain;
            outp_val = vcm + outDiff / 2.0;
            outm_val = vcm - outDiff / 2.0;
        }

        // Amplification complete on delayed clock edge
        @ cross(V(clk_d) - vtrans, +1) {
            done_val = 1.0;
            outp_val = vcm;
            outm_val = vcm;
        }

        // Output transitions
        V(done) <+ done_val * vlogic_high;
        V(outp_pre) <+ outp_val;
        V(outm_pre) <+ outm_val;

        // Reset behavior
        if (V(rst) > vtrans) {
            done_val = 1.0;
            V(outp) <+ vcm + I(outp) * 1.0;
            V(outm) <+ vcm + I(outm) * 1.0;
        } else if (done_val == 0.0) {
            V(outp) <+ V(outp_pre);
            V(outm) <+ V(outm_pre);
        }
    }
}