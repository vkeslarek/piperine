// Comparator
//
// Version 1a, 1 June 04
//
// Olaf Zinke
//
// Downloaded from The Designer's Guide Community (www.designers-guide.org).
// Post any questions on www.designers-guide.org/Forum.
// Taken from "The Designer's Guide to Verilog-AMS" by Kundert & Zinke.
// Chapter 4, Listing 14.

// Comparator with hysteresis using above() -> cross()

mod comparator_hyst(out, p, n) {
    param offset : Real = 0; // Offset voltage (V)
    param hyst : Real = 0.0 from [0:inf]; // Hysteresis (V)
    inout p : Electrical, inout n : Electrical;
    output out : Logic;
    var out : Bit;
    param thrlo : Real = offset - 0.5 * hyst; // Lower threshold voltage (V)
    param thrhi : Real = offset + 0.5 * hyst; // Upper threshold voltage (V)

    always @(above(V(p, n) - thrhi)) out = 1;
    always @(above(thrlo - V(p, n))) out = 0;
}