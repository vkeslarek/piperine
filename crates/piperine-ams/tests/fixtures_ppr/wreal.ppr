mod top;

digital top {
    var pass : Bit;
    var in_ : Real;
    wire out1 : Real;
    wire out2 : Real;
    wire outa : Real;
    var ca1 : Real = 2.25;
    var ca2 : Real;

    // assign ca2 = 4.5;

    // sub1 dut1(out1, in);
    // sub2 dut2(out2, in);
    // suba duta(outa, in);

    initial begin
        pass = 1;
        in_ = 1.0;
        # 1;
        if (out1 != 1.0) begin
            $display("FAILED: expected out1 to be 1.0, got %f", out1);
            pass = 0;
        end
        if (out2 != 1.0) begin
            $display("FAILED: expected out2 to be 1.0, got %f", out2);
            pass = 0;
        end
        if (outa != 1.0) begin
            $display("FAILED: expected outa to be 1.0, got %f", outa);
            pass = 0;
        end
        if (ca1 != 2.25) begin
            $display("FAILED: expected ca1 to be 2.25, got %f", ca1);
            pass = 0;
        end
        if (ca2 != 4.5) begin
            $display("FAILED: expected ca1 to be 4.5, got %f", ca2);
            pass = 0;
        end

        if (pass != 0) $display("PASSED");
    end
}

mod sub1 ( output out : Real, input in_ : Real ) {
    digital sub1 {
        out <- in_;
    }
}

mod sub2 ( output out : Real, input in_ : Real ) {
    digital sub2 {
        out <- in_;
    }
}

mod suba ( output out : Real, input in_ : Real ) {
    digital suba {
        out <- in_;
    }
}

endmodule