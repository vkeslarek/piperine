// Current Authors: Matthias Bucher, Nikolaos Makris
// Initial Authors: Antonios Bazigos, Matthias Bucher, Francois Krummenacher

// MODE SELECTION
// DC_S, DC, RF_S, RF, NQS modes available
// The user can choose between five modes that differentiate by internal nodes

mod ekv3(d, g, s, b);
    wire d, g, s, b:Electrical;
    wire di, si:Electrical;
    wire gi, bi:Electrical;
    wire bdi, bsi:Electrical;
    wire m1, m2, m3, m4:Electrical;
    wire noi:Electrical;

    // Instance parameters
    param:Real L = 1.0e-5 from [ 0 : inf);
    param:Real W = 1.0e-5 from [ 0 : inf);
    param:Real PS = 0.0 from [ 0 : inf);
    param:Real PD = 0.0 from [ 0 : inf);
    param:Real AS = 0.0 from [ 0 : inf);
    param:Real AD = 0.0 from [ 0 : inf);
    param:Real M = 1.0 from [ 0 : inf);
    param:Natural NF = 1 from [ 1 : inf);
    param:Real SA = 0.0;
    param:Real SB = 0.0;

    // Model parameters (from ekv3_parameters.va)
    param:Natural TYPE = 1 from [ -1 : 1 ] exclude 0;
    param:Real TOX = 3.0e-9 from [ 0 : inf);
    param:Real VFB = -0.5;
    param:Real PHI = 0.7 from [ 0 : inf);
    param:Real UC1 = 0.1 from [ 0 : inf);
    param:Real U0 = 0.05 from [ 0 : inf);
    param:Real ETA = 0.0 from [ 0 : 1];
    param:Real EGA = 11.7;
    param:Real GAMMA = 0.5 from [ 0 : inf);
    param:Real Q0 = 1e-6 from [ 0 : inf);
    param:Real LAMBDA = 0.0;
    param:Real DK = 0.0;
    param:Real XJ = 1.5e-7 from [ 0 : inf);
    param:Real N = 1.0 from [ 0 : inf);
    // ... (many more model parameters from ekv3_parameters.va)

    // Variables (from ekv3_variables.va)
    var VG, VD, VS, VB;
    var Vds, Vgs, Vbs;
    var Vth, Vt;
    var beta;
    var gamma, gamma_b, gamma_g;
    var psi_p, sqrt_psi_p;
    var vp_dibl, vp_dibl_edge;
    var qs, qd, qi, qb;
    var IDS, IG;
    var n, nslope;
    var gm, gds, gmbs;
    var ispec_dits, Ispec_dits;
    var Q0_i, Q0_edge;
    var Leff, Weff, WeffNF;
    var UT, sqrtUT;
    var EG, ni;
    var T, Tnom, dT;
    // ... (many more variables)

    // Clamped exponential function (lexp)
    function lexp(x) = (x > 80.0) ? 5.540622384e+34 * (1.0 + x - 80.0) :
                      (x < -80.0) ? 1.804851387e-35 : exp(x);

    analog ekv3 {
        // From ekv3_include/ekv3_variables.va
        // From `MODEL
        // EKV3 model equations

        begin : EKV3
            // GENERAL_VALUES - simulation flags
            // LEVEL 0 - model level calculations

            // From ekv3_include/ekv3_functions_def.va
            // QV, NQ, QX, QG function calls

            // Channel current calculation
            // Charge calculations (qs, qd, qi, qb)
            // Mobility reduction
            // Short channel effects (DIBL)
            // Velocity saturation
            // Geometry scaling (W, L, NF dependencies)

            // From ekv3_include/ekv3_edge.va
            // Edge device effects

            // From ekv3_include/ekv3_extrinsic_diodes.va
            // Source/drain junction diodes

            // From ekv3_include/ekv3_extrinsic_rc.va
            // External resistors and overlap capacitances

            // From ekv3_include/ekv3_oppoints.va
            // Operating point output variables

            // From ekv3_include/ekv3_extract_debug.va
            // Debug and extraction variables
        end
    }
endmod