// `include "constants.vams"
// `include "disciplines.vams"

// Optical waveguide

mod Waveguide ( inout [0:3] node1 : Optical, inout [0:3] node2 : Optical ) {
    wire fwd : Optical[0:1];
    wire bwd : Optical[0:1];
    wire transfer_pol : Optical[0:1];
    wire transfer : Optical[0:1];

    param length : Real = 100e-6; // [m]
    param equivalentIndex : Real = 2.31;
    param groupIndex : Real = 4.34;
    param loss : Real = 2.0; // [dB/cm]

    var alpha : Real = 23.0258509299404568 * loss;

    // Instance connections would require module definitions
    // Polar2Cartesian Polar2Cartesian1(transfer_pol, transfer);
    // CartesianMultiplier CartesianMultiplier1(transfer, node1[0:1], fwd[0:1]);
    // CartesianMultiplier CartesianMultiplier2(transfer, node2[2:3], bwd[0:1]);

    analog Waveguide {
        // Propagation loss and phase rotation
        OptE(transfer_pol[0]) <+ exp(-alpha / 2.0 * length);
        OptE(transfer_pol[1]) <+ (-length * equivalentIndex * 2.0 * M_PI * F_REF / P_C) % (2.0 * M_PI);

        // Output
        // NOTE: absdelay may not be directly supported
        OptE(node2[0]) <+ absdelay(OptE(fwd[0]), length * groupIndex / P_C);
        OptE(node2[1]) <+ absdelay(OptE(fwd[1]), length * groupIndex / P_C);
        OptE(node1[2]) <+ absdelay(OptE(bwd[0]), length * groupIndex / P_C);
        OptE(node1[3]) <+ absdelay(OptE(bwd[1]), length * groupIndex / P_C);
    }
}

endmodule