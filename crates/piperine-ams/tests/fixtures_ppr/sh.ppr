// Self-clocked (periodic) sample and hold
//
// Version 1a, 1 June 04
//
// Ken Kundert
//
// Downloaded from The Designer's Guide Community (www.designers-guide.org).
// Post any questions on www.designers-guide.org/Forum.
// Taken from "The Designer's Guide to Verilog-AMS" by Kundert & Zinke.
// Chapter 3, Listing 24.

// `include "disciplines.vams"

mod sh ( inout p : Voltage, inout n : Voltage, input ps : Voltage, input ns : Voltage ) {
    param period : Real = 1.0; // from(0:inf) // sampling period (s)
    param toff : Real = 0.0; // from[0:inf) // offset time for sampling (s)
    param td : Real = 0.0; // from[0:inf) // delay from sampling to output (s)
    param tt : Real = period / 100.0; // from[0:inf) // duration of output transitions (s)
    var save : Real;

    analog sh {

        // Sample the input
        @(timer(toff, period) or initial) save = V(ps, ns);

        // Produce output with well-controlled transitions
        // NOTE: transition() function has limitations in PHDL
        V(p, n) <+ transition(save, td, tt);
    }
}

endmodule