// Note: This file is a module wrapper with includes. Complex model code not translated.
mod PSP103_VA(D, G, S, B);
    // Note: connectmodule - PSP 103.6 MOS transistor model
    inout D, G, S, B;
    wire D : Electrical, G : Electrical, S : Electrical, B : Electrical;
endmod