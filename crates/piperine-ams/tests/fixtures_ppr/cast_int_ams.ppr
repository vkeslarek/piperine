mod top {
    var pass : Bit = 1'b1;
    var in : Real;
    wire out[7:0] : Logic = in;

    initial {
        //    $monitor(in,, out);
        in = sqrt(-1.0);
        # 1;
        if (out !== 8'bxxxxxxxx) begin
            $display("Failed: nan expected 8'bxxxxxxxx, got %b", out);
            pass = 1'b0;
        end

        if (pass) $display("PASSED");
    }
}