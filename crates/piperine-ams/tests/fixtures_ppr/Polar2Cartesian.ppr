// Convert polar coordinates to Cartesian coordinates
mod Polar2Cartesian(pol, cart);
    input [ 0 : 1 ] pol;
    // pol[0] is amplitude, and pol[1] is phase
    output [ 0 : 1 ] cart;
    // cart[0] is real part, and cart[1] is imaginary part
    wire [ 0 : 1 ] pol : Optical, cart : Optical;

    analog SpicePolar2Cartesian {
        OptE(cart [ 0 ]) <+ OptE(pol [ 0 ]) * cos(OptE(pol [ 1 ]));
        // Real
        OptE(cart [ 1 ]) <+ OptE(pol [ 0 ]) * sin(OptE(pol [ 1 ]));
        // Imag
    }
endmod