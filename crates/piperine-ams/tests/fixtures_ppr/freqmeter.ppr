mod freqmeter(in);
    input in;
    voltage in;
    var tstart : Real;
    var file : Integer;

    analog begin
        @ initial begin
            file = $fopen("freqmeter.out");
        end

        @ cross(V(in), +1) begin
            if (tstart > 0) $fstrobe(file, "%g\t%g", $abstime, 1 / ($abstime - tstart));
            tstart = $abstime;
        end

        @ final_step $fclose(file);
    end
endmod