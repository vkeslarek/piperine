// Note: This file includes the L_UTSOI_102_macrodef.include file
// and then the L_UTSOI_102_module.include file.
// This translation captures the module structure.

mod l_utsoi(inout d : Electrical, inout g : Electrical, inout s : Electrical, inout b : Electrical, inout Tnode : Electrical) {
    wire d : Electrical, g : Electrical, s : Electrical, b : Electrical, Tnode : Electrical;

    // Channel type
    param type : Integer = 1; // constraint: -1 <= type <= 1, type != 0

    // Basic geometry parameters
    param l : Real = 1.0e-6; // constraint: l > 0
    param w : Real = 1.0e-6; // constraint: w > 0

    // Temperature parameters
    param tnom : Real = 27.0; // constraint: tnom >= 0
    param dtemp : Real = 0.0;

    // Multiplicity factor
    param mult : Real = 1.0; // constraint: mult >= 1

    analog l_utsoi {
        // Behavioral code not directly translatable
    }
}