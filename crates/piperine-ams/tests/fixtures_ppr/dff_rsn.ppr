// VerilogA for VerilogAmsLib, dff_rsn, veriloga

mod dff_rsn(d, clk, q, _q, _rst, _set) {
    input clk : Electrical, d : Electrical, _rst : Electrical, _set : Electrical;
    output q : Electrical, _q : Electrical;

    param vlogic_high : Real = 5;
    param vlogic_low : Real = 0;
    param vtrans_clk : Real = 2.5;
    param vtrans : Real = 2.5;
    param tdel : Real = 3u from [0:inf];
    param trise : Real = 1u from(0:inf);
    param tfall : Real = 1u from(0:inf);

    var x : Integer, rst_val : Integer, set_val : Integer;

    analog dff_rsn {
        rst_val = (V(_rst) < vtrans);
        set_val = (V(_set) < vtrans);
        @(cross(V(clk) - vtrans_clk, +1)) x = (((V(d) > vtrans) || set_val) && !rst_val);
        @(cross(V(_rst) - vtrans, -1)) x = 0;
        @(cross(V(_set) - vtrans, -1)) x = !rst_val;

        V(q) <+ vlogic_high * x + vlogic_low * !x; // transition not fully supported
        V(_q) <+ vlogic_high * !x + vlogic_low * x; // transition not fully supported
    }
}