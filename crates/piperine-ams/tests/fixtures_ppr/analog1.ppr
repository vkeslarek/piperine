// discipline voltage;
//     potential Voltage;
// enddiscipline

mod main;

    var value : Real;
    wire out : Voltage;

    analog main {
        V(out) <+ abs(value);
    }

    @ initial {
        value = 1.0;
        # 1 if (V(out) != abs(value)) begin
            $display("FAILED -- value=%g, res=%g", value, V(out));
            $finish;
        end

        value = -1.0;
        # 1 if (V(out) != abs(value)) begin
            $display("FAILED -- value=%g, res=%f", value, V(out));
            $finish;
        end

        $display("PASSED");
    }

endmod
// main