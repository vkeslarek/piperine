// Analog to Digital Converter
//
// Version 1a, 1 June 04
//
// Olaf Zinke
//
// Downloaded from The Designer's Guide Community (www.designers-guide.org).
// Post any questions on www.designers-guide.org/Forum.
// Taken from "The Designer's Guide to Verilog-AMS" by Kundert & Zinke.
// Chapter 4, Listing 12.

mod adc(out, in, clk);
    // resolution (bits)
    param bits : Natural = 8 from [ 1 : 24 ];
    // input range is from 0 to fullscale (V)
    param fullscale : Real = 1.0;
    // delay from clock to output (ns)
    param td : Real = 0;

    wire in : Voltage;
    wire clk : Voltage;
    var out : Logic;

    var sample : Real;
    var midpoint : Real;
    var i : Integer;

    @ posedge(clk) {
        sample = V(in);
        midpoint = fullscale / 2.0;
        for (i = bits - 1; i >= 0; i = i - 1) begin
            var over : Logic;
            over = (sample > midpoint);
            if (over) sample = sample - midpoint;
            sample = 2.0 * sample;
            out[i] <= # (td) over;
        end
    }
endmod