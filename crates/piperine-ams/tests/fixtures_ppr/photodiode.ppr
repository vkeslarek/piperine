mod photodiode(Anode, Cathode, Light);
    inout Anode, Cathode, Light;
    wire Anode, Cathode, Light : Electrical;
    wire n1 : Electrical;
    wire b6 : branch(Anode, n1);
    wire b1 : branch(n1, Cathode);

    param N : Real = 1.35 from [ 1e-6 : inf);
    param Rseries : Real = 1e-3 from [ 1e-6 : inf);
    param Is : Real = 0.34e-12 from [ 1e-20 : inf);
    param Bv : Real = 60 from [ 1e-6 : inf];
    param Ibv : Real = 1e-3 from [ 1e-6 : inf];
    param Vj : Real = 0.7 from [ 1e-6 : inf];
    param Cj0 : Real = 60e-12 from [ 0 : inf];
    param M : Real = 0.5 from [ 1e-6 : 1.0);
    param Area : Real = 1.0 from [ 1.0 : inf];
    param Tnom : Real = 26.85 from [ - 273 : inf];
    param Fc : Real = 0.5 from [ 1e-6 : inf];
    param Tt : Real = 10e-9 from [ 1e-20 : inf];
    param Xti : Real = 3.0 from [ 1e-6 : inf];
    param Eg : Real = 1.16 from [ 1e-6 : inf];
    param Responsivity : Real = 0.5 from [ 1e-6 : inf];
    param Rsh : Real = 5e8 from [ 1e-6 : inf];
    param QEpercent : Real = 80 from [ 0 : 100 ];
    param Lambda : Real = 900 from [ 100 : 2000 ];
    param LEVEL : Integer = 1 from [ 1 : 2 ];
    param Kf : Real = 1e-12 from [ 0 : inf];
    param Af : Real = 1.0 from [ 0 : inf];
    param Ffe : Real = 1.0 from [ 0 : inf];

    var A : Real;
    var B : Real;
    var T1 : Real;
    var T2 : Real;
    var F1 : Real;
    var F2 : Real;
    var F3 : Real;
    var Rseries_Area : Real;
    var Eg_T1 : Real;
    var Eg_T2 : Real;
    var Vt_T2 : Real;
    var Vj_T2 : Real;
    var Cj0_T2 : Real;
    var Is_T2 : Real;
    var GMIN : Real;
    var I1 : Real;
    var I2 : Real;
    var I3 : Real;
    var I4 : Real;
    var I5 : Real;
    var Id : Real;
    var V1 : Real;
    var Q1 : Real;
    var Q2 : Real;
    var fourkt : Real;
    var TwoQ : Real;
    var Res1 : Real;
    var Res2 : Real;
    var Res : Real;
    var Vt : Real;
    var I_flicker : Real;
    var con1 : Real;
    var con2 : Real;
    var con3 : Real;
    var con4 : Real;
    var con5 : Real;
    var con6 : Real;

    analog begin
        @(initial_step) begin
            Rseries_Area = (Rseries + 1e-10) / Area;
            A = 7.02e-4;
            B = 1108.0;
            T1 = Tnom + 273.15;
            T2 = $temperature;
            Vt = `P_K * 300.0 / `P_Q;
            Vt_T2 = `P_K * T2 / `P_Q;
            F1 = (Vj / (1 - M)) * (1 - pow((1 - Fc), (1 - M)));
            F2 = pow((1 - Fc), (1 + M));
            F3 = 1 - Fc * (1 + M);
            Eg_T1 = Eg - A * T1 * T1 / (B + T1);
            Eg_T2 = Eg - A * T2 * T2 / (B + T2);
            Vj_T2 = (T2 / T1) * Vj - 2 * 8.617e-5 * temp * ln(pow((T2 / T1), 1.5)) - ((T2 / T1) * Eg_T1 - Eg_T2);
            GMIN = 1e-12;
            Cj0_T2 = Cj0 * (1 + M * (400e-6 * (T2 - T1) - (Vj_T2 - Vj) / Vj));
            Is_T2 = Is * pow((T2 / T1), (Xti / N)) * exp(-(Eg_T1) / (8.617e-5 * temp) * (1 - T2 / T1));
            Res1 = (QEpercent != 0) ? QEpercent * Lambda / 1.2398e5 : Responsivity;
            Res2 = QEpercent * Lambda / 1.2938e5;
            Res = (LEVEL == 1) ? Res1 : Res2;
            con1 = -5.0 * N * Vt;
            con2 = Area * Is_T2;
            con3 = Area * Cj0_T2;
            con4 = Fc * Vj;
            con5 = Fc * Vj_T2;
            con6 = Bv / Vt_T2;
        end
        V1 = V(b1);
        I1 = (V1 > con1) ? con2 * (exp(V1 / (N * Vt_T2)) - 1.0) + GMIN * V1 : 0;
        I2 = (V1 <= con1) ? -con2 + GMIN * V1 : 0;
        I3 = (V1 == -Bv) ? -Ibv : 0;
        I4 = (V1 < -Bv) ? -con2 * (exp(-(Bv + V1) / Vt_T2) - 1.0 + con6) : 0;
        Q1 = (V1 < con4) ? Tt * I1 + con3 * (Vj_T2 / (1 - M)) * (1 - pow((1 - V1 / Vj_T2), (1 - M))) : 0;
        Q2 = (V1 >= con4) ? Tt * I1 + con3 * (F1 + (1 / F2) * (F3 * (V1 - con5) + (M / (2.0 * Vj_T2)) * (V1 * V1 - con5 * con5))) : 0;
        I5 = V(Light) * Res;
        Id = I1 + I2 + I3 + I4;
        I(b1) <+ -I5;
        I(b1) <+ V(b1) / Rsh;
        I(b6) <+ V(b6) / Rseries_Area;
        I(b1) <+ Id;
        I(b1) <+ ddt(Q1 + Q2);
        I(Light) <+ V(Light) / 1e10;
        fourkt = 4.0 * `P_K * $temperature;
        TwoQ = 2.0 * `P_Q;
        I_flicker = pow(Id, Af);
        I(b6) <+ white_noise(fourkt / Rseries_Area, "thermal");
        I(b1) <+ white_noise(fourkt / Rsh, "thermal");
        I(b1) <+ white_noise(TwoQ * Id, "shot");
        I(b1) <+ flicker_noise(Kf * I_flicker, Ffe, "flicker");
        I(b1) <+ white_noise(TwoQ * I5, "shot");
    end
endmod