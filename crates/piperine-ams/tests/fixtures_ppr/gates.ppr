// Post any questions to www.designers-guide.org/Forum

//
// 2-input Nand gate
//

mod anand(out, in1, in2);

    output out;
    voltage out;
    input in1, in2;
    voltage in1, in2;
    param vh : Real = 1;
    // output voltage in high state
    param vl : Real = 0;
    // output voltage in low state
    param vth : Real = (vh + vl) / 2;
    // threshold voltage at inputs
    param td : Real = 0 from [ 0 : inf);
    // delay to start of output transition
    param tt : Real = 0 from [ 0 : inf);
    // transition time of output signals

    analog begin
        @(cross(V(in1) - vth) or cross(V(in2) - vth));

        V(out) <+ transition(!((V(in1) > vth) && (V(in2) > vth)) ? vh : vl, td, tt);
    end
endmod

//
// 2-input Nor gate
