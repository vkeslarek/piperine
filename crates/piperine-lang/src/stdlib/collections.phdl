// Standard library higher-order collection functions.
// N is an implicit compile-time const inferred from the array dimension.

fn map<T, U>(xs: T[N], f: fn(T) -> U) -> U[N] {
    return [ f(xs[i]) | i in 0..N ];
}

fn reduce<T>(xs: T[N], op: fn(T, T) -> T) -> T {
    if (N == 1) { return xs[0]; }
    return op( reduce(xs[0..N/2], op), reduce(xs[N/2..N], op) );
}
