// Smoke tests for the models that simulate through the current piperine JIT:
// passives, independent sources (DC / transient / AC), controlled sources and
// switches.  Junction devices (dio/bjt/mos1/jfet) are faithful translations but
// need core features that are not yet lowered in the JIT — see README.md
// "Simulation status" and the piperine ROADMAP ($limit, IC-in-events, large
// analog bodies).  Run with:  piperine test tests/validate.phdl
//
// The independent source used here is the library's own `vsrc`, which now
// drives AC analysis via the force-branch `ac_stim` support added to piperine.

use piperine::disciplines;
use spice::passives;
use spice::sources;
use spice::controlled;
use spice::switches;

// ── Resistive divider: exercises res + vsrc DC ──────────────────────────────
mod Divider() {
    wire gnd : Electrical;
    wire vin : Electrical;
    wire mid : Electrical;
    vs : vsrc (.p = vin, .n = gnd) { .dc = 10.0 };
    r1 : res  (.p = vin, .n = mid) { .r = 1.0e3 };
    r2 : res  (.p = mid, .n = gnd) { .r = 3.0e3 };
}

bench Divider {
    fn test_ratio() {
        var r = $op();
        $display("mid:", r.v(mid, gnd));
        $assert(abs(r.v(mid, gnd) - 7.5) < 1.0e-6, "10 V · 3k/(1k+3k) = 7.5 V");
    }
}

// ── RC low-pass driven by an AC voltage source ──────────────────────────────
mod RcLowpass() {
    wire gnd : Electrical;
    wire vin : Electrical;
    wire out : Electrical;
    vs : vsrc (.p = vin, .n = gnd) { .dc = 0.0, .ac_mag = 1.0 };
    r1 : res  (.p = vin, .n = out) { .r = 1591.5 };   // fc = 1/(2πRC) ≈ 100 kHz
    c1 : cap  (.p = out, .n = gnd) { .c = 1.0e-9 };
}

bench RcLowpass {
    fn test_corner() {
        var tr = $ac(AcConfig { .fstart = 1.0e3, .fstop = 1.0e6, .points = 40 });
        var mag = tr.v(out, gnd).mag();
        $display("|H| @1kHz:", mag.at(1.0e3), " @100kHz:", mag.at(1.0e5));
        $assert(mag.at(1.0e3) > 0.99, "passband gain ≈ 1");
        $assert(mag.at(1.0e5) > 0.69 && mag.at(1.0e5) < 0.72, "−3 dB at the corner");
    }
}

// ── VCVS gain stage ─────────────────────────────────────────────────────────
mod Amp() {
    wire gnd : Electrical;
    wire vin : Electrical;
    wire out : Electrical;
    vs : vsrc (.p = vin, .n = gnd) { .dc = 0.5 };
    e1 : vcvs (.p = out, .n = gnd, .cp = vin, .cn = gnd) { .gain = 4.0 };
}

bench Amp {
    fn test_gain() {
        var r = $op();
        $display("out:", r.v(out, gnd));
        $assert(abs(r.v(out, gnd) - 2.0) < 1.0e-6, "VCVS: 4 · 0.5 V = 2 V");
    }
}
