discipline Electrical {
    potential v : Real;
    flow i : Real;
}

discipline Bit {
    storage Boolean;
}

mod Adc(input vin : Electrical, output d_out : Bit) {
    param vref : Real = 0.9;
}

digital Adc {
    d_out <- (V(vin) > vref);
}

bench Adc {
    fn test_op_solves() {
        var r = $op();
        $assert(1 == 1, "Adc reaches a DC operating point");
    }
}
