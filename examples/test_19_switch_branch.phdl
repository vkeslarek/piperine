discipline Electrical {
    potential v : Real;
    flow i : Real;
}

discipline Bit {
    storage Boolean;
}

mod Switch(input ctrl : Bit, inout a : Electrical, inout b : Electrical) { }

analog Switch {
    if (ctrl == 1) {
        V(a, b) <- 0.0;
    } else {
        I(a, b) <- 0.0;
    }
}

bench Switch {
    fn test_op_solves() {
        var res = $op();
        $assert(1 == 1, "Switch reaches a DC operating point");
    }
}
