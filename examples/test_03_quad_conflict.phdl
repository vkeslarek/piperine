discipline Logic {
    storage Quad;
    resolve tri;
}

mod Driver1(inout bus : Logic) { }

digital Driver1 {
    bus <- 0q1;
}

mod Driver2(inout bus : Logic) { }

digital Driver2 {
    bus <- 0q0;
}

mod TopLevel(inout bus : Logic) {
    d1 : Driver1(bus);
    d2 : Driver2(bus);
}

bench TopLevel {

    fn test_op_solves() {
        var r = $op ();
        $assert (1 == 1, "conflicting quad drivers still resolve to a DC operating point");
    }
}
