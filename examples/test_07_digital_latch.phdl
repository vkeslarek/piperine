discipline Bit {
    storage Boolean;
}

mod SrLatch(input s : Bit, input r : Bit, output q : Bit) {
    var st : Bit = 0;
}

digital SrLatch {
    q <- st;
    @(posedge(s) | posedge(r)) {
        if (s == 1) {
            st = 1;
        } else {
            st = 0;
        }
    }
}

bench SrLatch {

    fn test_op_solves() {
        var res = $op ();
        $assert (1 == 1, "SrLatch reaches a DC operating point");
    }
}
