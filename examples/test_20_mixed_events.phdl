discipline Bit {
    storage Boolean;
}

mod MixedEvents(input clk : Bit, input clk2 : Bit, output trig : Bit) {
    var st : Bit = 0;
}

digital MixedEvents {
    trig <- st;
    @(posedge(clk) | posedge(clk2)) {
        st = !st;
    }
}

bench MixedEvents {

    fn test_op_solves() {
        var res = $op ();
        $assert (1 == 1, "MixedEvents reaches a DC operating point");
    }
}
