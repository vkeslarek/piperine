discipline Electrical {
    potential v : Real;
    flow i : Real;
}

mod Capacitor[N] (inout p : Electrical, inout n : Electrical) {
    param c : Real = 1e-12;
}

analog Capacitor {
    I(p, n) <+ c * ddt(V(p, n));
}

mod Resistor(inout p : Electrical, inout n : Electrical) {
    param r : Real = 1e12;
}

analog Resistor {
    I(p, n) <+ V(p, n) / r;
}

mod Top() {
    wire cp : Electrical;
    wire gnd : Electrical;
    c1 : Capacitor[8](cp, gnd);
    // A pure capacitor has no DC operating point on its own (zero
    // conductance at DC); a high-value bias resistor gives the bench a
    // well-posed $op() without perturbing the transient behavior.
    bias : Resistor(cp, gnd);
}

bench Top {
    fn test_capacitor_rests_near_ground() {
        var res = $op();
        $assert(res.v(cp, gnd) < 1e-6, "no source: a lone capacitor should rest near 0V at DC");
    }
}
