discipline Bit {
    storage Boolean;
}

mod MatchTest(input clk : Bit) {
    var m : Boolean = 0;
    var x : Bit = 0;
}

digital MatchTest {
    @posedge(clk) {
        match m {
            _ => {
                x = 1;
            }
        }
    }
}

bench MatchTest {

    fn test_op_solves() {
        var res = $op ();
        $assert (1 == 1, "MatchTest reaches a DC operating point");
    }
}
