discipline Electrical {
    potential v : Real;
    flow i : Real;
}

bundle Differential {
    p : Electrical, n : Electrical,
}

mod DiffAmp(input in : Differential, output out : Differential) {
    param gain : Real = 10.0;
}

analog DiffAmp {
    V(out.p, out.n) <+ gain * V(in.p, in.n);
}

mod Top() {
    wire sig_in : Differential;
    wire sig_out : Differential;

    amp : DiffAmp(.in = sig_in,.out = sig_out);
}

// No bench here: `sig_in.p`/`sig_in.n` have no DC path to ground at all (the
// VCVS only drives `out` from `in`, never the reverse) — `$op()` is
// structurally singular. A bench would need bias resistors wired onto the
// bundle-expanded input nets; deferred until bundle net-field addressing
// from a mod body is exercised elsewhere.
