discipline Electrical {
    potential v : Real;
    flow i : Real;
}

mod MathTest(inout p : Electrical) { }

analog MathTest {
    var x : Real = exp(1.0);
    var y : Real = ln(x);
    var z : Real = sqrt(4.0);
    var w : Real = pow(2.0, 3.0);
    V(p) <- x + y + z + w;
}

mod Top() {
    wire node : Electrical;
    // A bench-able top must have a child instance: a leaf top's own
    // `analog`/`digital` body is only compiled into the circuit when it
    // *also* has instances (`CircuitCompiler::build_circuit`) — a bare
    // `bench MathTest` would see an empty circuit and never actually force
    // `p`.
    m1 : MathTest(node);
}

bench Top {
    fn test_math_functions_force_p() {
        var res = $op();
        // exp(1) + ln(exp(1)) + sqrt(4) + pow(2,3) = e + 1 + 2 + 8 = e + 11
        $assert(res.v(node, gnd) > 13.71 && res.v(node, gnd) < 13.72, "V(p) should be e + 11");
    }
}
