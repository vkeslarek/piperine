discipline Logic {
    storage Quad;
    resolve tri;
}

mod BusTest(inout bus : Logic) {
    var val : Boolean = 0;
}

digital BusTest {
    bus <- val;
}

bench BusTest {

    fn test_op_solves() {
        var res = $op ();
        $assert (1 == 1, "BusTest reaches a DC operating point");
    }
}
