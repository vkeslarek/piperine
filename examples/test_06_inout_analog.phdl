discipline Electrical {
    potential v : Real;
    flow i : Real;
}

mod Resistor(inout p : Electrical, inout n : Electrical) {
    param r : Real = 1000.0;
}

analog Resistor {
    I(p, n) <+ V(p, n) / r;
}

bench Resistor {

    fn test_floating_resistor_rests_near_ground() {
        var r = $op ();
        $assert (r.v(p, n) < 1e-6, "no source: p and n should both settle near 0V");
    }
}
