discipline Electrical {
    potential v : Real;
    flow i : Real;
}

mod Resistor(inout p : Electrical, inout n : Electrical) {
    param r : Real = 100.0;
}

mod Ladder(inout bus : Electrical, inout gnd : Electrical) {
    param cpar : Real = 1e-15;
    wire tap : Electrical[5];
    for i in 0 .. 5 {
        rseg[i] : Resistor(bus, tap[i]);
    }
}

analog Ladder {
    for i in 0 .. 5 {
        I(rseg[i].n, gnd) <+ cpar * ddt(V(rseg[i].n, gnd));
    }
}

// No bench here: `Ladder` itself instantiates `Resistor` (one level of
// hierarchy already), and the codegen path a bench drives
// (`CircuitCompiler::build_circuit_mapped`) does not yet flatten nested
// hierarchy — a bench can only attach to a module whose own instances are
// all leaves. Wrapping `Ladder` in a `Top()` to add a bias resistor would
// create that second level and hits the same "flatten during elaboration"
// limit. Bench-ing `Ladder` directly is also structurally singular at DC
// (every tap reaches `gnd` only through a zero-conductance capacitor).
// Deferred until either hierarchy flattening or `$tran` (where the
// capacitors' own dynamics resolve the initial condition) lands.
